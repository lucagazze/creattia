---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import '@fontsource-variable/manrope';

const plans = [
	{ code: 'creator', name: 'Creator', price: 19, credits: 40, copy: 'Para mantener tus redes activas todas las semanas.', featured: false },
	{ code: 'pro', name: 'Pro', price: 39, credits: 120, copy: 'Para probar más ideas y encontrar lo que mejor vende.', featured: true },
	{ code: 'scale', name: 'Scale', price: 79, credits: 300, copy: 'Para equipos que producen contenido todos los días.', featured: false },
];

const businessTypes = [
	{ name: 'E-commerce', color: '#a77bf7', icon: 'M3 4h2l2 10h10l2-7H6m3 12a1 1 0 1 0 0 .01M17 19a1 1 0 1 0 0 .01' },
	{ name: 'Gastronomía', color: '#ff9b63', icon: 'M7 3v7m-2-7v4a2 2 0 0 0 4 0V3M7 10v11m8-18c-2 3-2 7 1 9v9m0-9V3' },
	{ name: 'Moda', color: '#f27cb0', icon: 'M12 7a2 2 0 1 0-2-2m2 2v2L3 17h18L12 9' },
	{ name: 'Belleza', color: '#df8cff', icon: 'M12 3c3 4 5 7 5 10a5 5 0 0 1-10 0c0-3 2-6 5-10m6 1v4m-2-2h4' },
	{ name: 'Fitness', color: '#6ed5a1', icon: 'M4 9v6m3-8v10m10-10v10m3-8v6M7 12h10M2 11v2m20-2v2' },
	{ name: 'Servicios', color: '#75b7ff', icon: 'M9 6V4h6v2m-11 0h16v13H4zM4 11h16M9 11v2h6v-2' },
	{ name: 'Productos digitales', color: '#ffd16c', icon: 'M4 4h16v16H4zM4 8h16m-8 4 4 2.5-4 2.5z' },
	{ name: 'Apps y SaaS', color: '#8f95ff', icon: 'M5 4h5v5H5zm9 0h5v5h-5zM5 14h5v5H5zm9 0h5v5h-5z' },
];

const faqs = [
	{ q: '¿Es un pack de imágenes?', a: 'No. Es una aplicación con una biblioteca de ideas que crece dentro de tu cuenta. Elegís una, sumás tu producto y generás una versión para tu marca.' },
	{ q: '¿Necesito saber diseñar o escribir prompts?', a: 'No. Creattia prepara las instrucciones por vos. Solo elegís la idea, el producto y el formato.' },
	{ q: '¿Cómo usa mi marca y mis productos?', a: 'Conectás tu web e Instagram una vez. Creattia analiza tu identidad e importa tus productos para tenerlos listos cada vez que creás.' },
	{ q: '¿Puedo agregar una indicación propia?', a: 'Sí, pero es opcional. Si no escribís nada, Creattia usa la información de tu marca, tu producto y la idea seleccionada.' },
	{ q: '¿Cómo funciona la prueba gratuita?', a: 'Creás tu cuenta y recibís 3 generaciones para probar el flujo completo. No necesitás tarjeta.' },
	{ q: '¿Puedo modificar una imagen generada?', a: 'Sí. Podés cambiar el producto, conservar el ángulo o pedir una versión muy parecida, más libre o completamente nueva.' },
];
---

<Layout
	title="Creattia | Imágenes con IA que venden"
	description="Elegí una idea, sumá tu producto y generá imágenes listas para vender con tu marca. Probá 3 generaciones gratis."
	ogTitle="Creattia | La plataforma N°1 para generar imágenes que venden"
	ogDescription="Generá anuncios y fotos de producto con tu marca, sin diseñar ni escribir prompts. Probá 3 imágenes gratis."
	ogImage="/images/creattia/moki-og.jpg"
	favicon="/images/creattia/moki-favicon-96.png"
	appleTouchIcon="/images/creattia/moki-apple-touch.png"
	manifest="/creattia.webmanifest"
	noindex={true}
>
	<header class="nav-shell">
		<div class="nav-inner">
			<a href="#top" class="brand" aria-label="Creattia, volver al inicio">
				<img src="/images/creattia/moki-mascot.webp" alt="" width="1254" height="1254" />
				<b>Creattia</b>
			</a>
			<a href="/app/" class="button button-small">
				<span>Empezar gratis</span>
				<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
			</a>
		</div>
	</header>

	<main id="top">
		<section class="hero">
			<div class="hero-grid" aria-hidden="true"></div>
			<div class="hero-orb hero-orb-one" aria-hidden="true"></div>
			<div class="hero-orb hero-orb-two" aria-hidden="true"></div>
			<div class="hero-inner">
				<div class="hero-copy">
					<span class="eyebrow"><i></i> IMÁGENES CON IA PARA NEGOCIOS</span>
					<h1>La plataforma N°1 para generar <em>imágenes que venden.</em></h1>
					<p>Elegí una idea, sumá tu producto y generá anuncios listos para vender. <strong>Sin diseñar ni escribir prompts.</strong></p>
					<div class="hero-actions">
						<a href="/app/" class="button button-primary">Crear 3 imágenes gratis <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg></a>
						<span><b>✓</b> Google o email · Sin tarjeta</span>
					</div>
				</div>

				<div class="hero-showcase">
					<div class="showcase-video">
						<video autoplay muted loop playsinline preload="auto" poster="/videos/creattia-hero.jpg" aria-label="Creattia transforma una foto de producto en una imagen lista para vender">
							<source src="/videos/creattia-hero.mp4" type="video/mp4" />
						</video>
					</div>
				</div>

				<div class="hero-proof" aria-label="Beneficios principales">
					<span><strong>3 gratis</strong><small>para probar todo</small></span>
					<i></i>
					<span><strong>Tu marca lista</strong><small>sin cargarla de nuevo</small></span>
					<i></i>
					<span><strong>Creá en minutos</strong><small>de producto a anuncio</small></span>
					<i></i>
					<span><strong>Nuevas ideas</strong><small>cada semana</small></span>
				</div>
			</div>
		</section>

		<div class="post-hero">
			<section class="bento-showcase" id="biblioteca">
				<div class="bento-grid">
					<article class="bento-card bento-ad">
						<div class="bento-copy">
							<span>ANUNCIOS</span>
							<h2>Ideas pensadas<br />para vender.</h2>
							<p>Ofertas, cuotas, lanzamientos y más.</p>
						</div>
						<div class="visual-phone" aria-hidden="true">
							<div class="phone-notch"></div>
							<div class="phone-canvas">
								<small>HOY</small>
								<strong>ENVÍO<br />GRATIS</strong>
								<div class="product-bottle"><i></i></div>
								<span>COMPRAR AHORA</span>
							</div>
						</div>
					</article>

					<article class="bento-card bento-product">
						<div class="bento-copy">
							<span>PRODUCTO</span>
							<h2>Fotos que hacen<br />que se vea mejor.</h2>
							<p>Tu producto, con una imagen lista para publicar.</p>
						</div>
						<div class="product-stage" aria-hidden="true">
							<div class="stage-ring"></div>
							<div class="stage-product"><i></i><strong>CREATTIA</strong></div>
							<span class="stage-star star-one">✦</span><span class="stage-star star-two">✦</span>
						</div>
					</article>

					<article class="bento-card bento-social">
						<div class="bento-copy">
							<span>REDES</span>
							<h2>Contenido sin<br />quedarte sin ideas.</h2>
							<p>Historias, posteos y piezas para tu calendario.</p>
						</div>
						<div class="social-stack" aria-hidden="true">
							<div class="social-card social-one"><small>NUEVO</small><strong>LANZAMIENTO</strong><i></i></div>
							<div class="social-card social-two"><small>3 CUOTAS</small><strong>SIN INTERÉS</strong><i></i></div>
							<div class="social-card social-three"><small>SOLO HOY</small><strong>20% OFF</strong><i></i></div>
						</div>
					</article>

					<article class="bento-card bento-library">
						<div class="bento-copy bento-copy-light">
							<span>BIBLIOTECA</span>
							<h2>Siempre hay una<br />idea para probar.</h2>
							<p>Nuevas categorías y formatos cada semana.</p>
							<a href="/app/">Explorar gratis <b>→</b></a>
						</div>
						<img src="/images/creattia/moki-mascot.webp" alt="" width="1254" height="1254" loading="lazy" />
						<div class="library-glow" aria-hidden="true"></div>
					</article>
				</div>
			</section>

			<section class="process-section" id="como-funciona">
				<div class="process-heading section-inner">
					<span>ASÍ DE SIMPLE</span>
					<h2>Cómo funciona</h2>
					<p>De tu producto a una imagen lista para vender, sin aprender diseño ni inteligencia artificial.</p>
				</div>

				<div class="process-list section-inner">
					<article class="process-item">
						<div class="process-visual process-connect" aria-hidden="true">
							<div class="orbit orbit-one"></div><div class="orbit orbit-two"></div>
							<img src="/images/creattia/moki-mascot.webp" alt="" width="1254" height="1254" loading="lazy" />
							<span class="source-chip chip-web">↗ Web</span>
							<span class="source-chip chip-instagram">◎ Instagram</span>
							<span class="source-chip chip-products">◇ Productos</span>
						</div>
						<div class="process-pill"><b>1</b><span>Conectá tu negocio. Creattia entiende tu marca.</span></div>
					</article>

					<article class="process-item">
						<div class="process-visual process-choose" aria-hidden="true">
							<div class="idea-card idea-back"><small>OBJETIVO</small><strong>Vender más</strong></div>
							<div class="idea-card idea-mid"><small>CATEGORÍA</small><strong>Promociones</strong></div>
							<div class="idea-card idea-front"><small>IDEA</small><strong>Envío gratis</strong><span>✓</span></div>
							<i class="idea-spark spark-one">✦</i><i class="idea-spark spark-two">✦</i>
						</div>
						<div class="process-pill"><b>2</b><span>Elegí una idea, tu producto y el formato.</span></div>
					</article>

					<article class="process-item">
						<div class="process-visual process-generate" aria-hidden="true">
							<div class="generate-orb"></div>
							<div class="result-creative"><small>LISTO PARA PUBLICAR</small><strong>ENVÍO<br />GRATIS</strong><div class="result-product"><i></i></div></div>
							<span class="generate-star star-a">✦</span><span class="generate-star star-b">✦</span>
						</div>
						<div class="process-pill"><b>3</b><span>Generá, descargá o pedí otra versión.</span></div>
					</article>
				</div>
			</section>

			<section class="engine-section">
				<div class="engine-heading section-inner">
					<span>TODO DENTRO DE CREATTIA</span>
					<h2>Creá sin fricción.<br /><em>Volvé cuando quieras.</em></h2>
					<p>Tus ideas, productos, favoritos y creaciones quedan organizados para que la próxima imagen salga todavía más rápido.</p>
				</div>

				<div class="engine-grid section-inner">
					<article class="engine-card engine-search">
						<div>
							<span>ENCONTRÁ TODO RÁPIDO</span>
							<h3>La idea exacta.<br />En pocos clics.</h3>
							<p>Buscá por objetivo, categoría o tipo de imagen.</p>
						</div>
						<div class="search-path" aria-hidden="true">
							<div><small>1 · OBJETIVO</small><strong>Vender más</strong></div><i>→</i>
							<div><small>2 · CATEGORÍA</small><strong>Promociones</strong></div><i>→</i>
							<div><small>3 · TIPO</small><strong>Envío gratis</strong></div><b>✓</b>
						</div>
					</article>

					<article class="engine-card engine-edit">
						<span>AJUSTÁ SIN EMPEZAR DE CERO</span>
						<h3>Una imagen.<br />Todas sus versiones.</h3>
						<div class="version-visual" aria-hidden="true">
							<div class="version-card"><small>ORIGINAL</small><strong>20% OFF</strong></div>
							<div class="version-arrow">→</div>
							<div class="version-card version-new"><small>NUEVA VERSIÓN</small><strong>ENVÍO GRATIS</strong></div>
						</div>
						<p>Cambiá el producto, conservá el ángulo o pedí algo diferente.</p>
					</article>

					<article class="engine-card engine-save">
						<div>
							<span>TODO QUEDA GUARDADO</span>
							<h3>Tu trabajo sigue<br />donde lo dejaste.</h3>
						</div>
						<ul>
							<li><i>♥</i><span><strong>Favoritos</strong><small>Guardá las ideas que más usás.</small></span></li>
							<li><i>↺</i><span><strong>Historial</strong><small>Volvé a una creación anterior.</small></span></li>
							<li><i>✦</i><span><strong>Nuevas versiones</strong><small>Iterá sin perder el resultado original.</small></span></li>
						</ul>
					</article>
				</div>
			</section>

			<section class="pricing-section" id="planes">
				<div class="pricing-heading section-inner">
					<span>EMPEZÁ GRATIS. CRECÉ CUANDO QUIERAS.</span>
					<h2>Planes simples</h2>
					<p>Elegí la cantidad de imágenes que necesitás cada mes. Todos los planes incluyen la experiencia completa.</p>
					<div class="billing-pill" aria-label="Facturación mensual"><b>Mensual</b><span>Sin permanencia</span></div>
				</div>

				<div class="plans-grid section-inner">
					{plans.map((plan) => (
						<article class:list={{ featured: plan.featured }}>
							<div class="plan-top">
								<span>{plan.name}</span>
								{plan.featured && <b>MÁS ELEGIDO</b>}
							</div>
							<h3><small>USD</small>{plan.price}<em>/mes</em></h3>
							<p>{plan.copy}</p>
							<strong>{plan.credits} imágenes por mes</strong>
							<a href={'/app/?plan=' + plan.code}>Elegir {plan.name}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg></a>
							<ul>
								<li>✓ Biblioteca completa</li>
								<li>✓ Marca y productos guardados</li>
								<li>✓ Historial, favoritos y versiones</li>
								<li>✓ Nuevas ideas cada semana</li>
							</ul>
						</article>
					))}
				</div>
				<p class="plan-note">Primero probá 3 imágenes gratis. No necesitás tarjeta.</p>
			</section>

			<section class="business-section">
				<div class="business-marquee" aria-label="Tipos de negocio compatibles">
					<div class="business-track">
						<div class="business-set">{businessTypes.map((business) => <span style={'--business-accent:' + business.color}><i><svg viewBox="0 0 24 24" aria-hidden="true"><path d={business.icon} /></svg></i><b>{business.name}</b></span>)}</div>
						<div class="business-set" aria-hidden="true">{businessTypes.map((business) => <span style={'--business-accent:' + business.color}><i><svg viewBox="0 0 24 24" aria-hidden="true"><path d={business.icon} /></svg></i><b>{business.name}</b></span>)}</div>
					</div>
				</div>
				<div class="business-heading section-inner">
					<span>PARA NEGOCIOS REALES</span>
					<h2>Si tenés algo para vender,<br /><em>tenés algo para crear.</em></h2>
					<p>Productos, servicios o negocios digitales. Sin experiencia en diseño ni IA.</p>
				</div>
			</section>

			<section class="faq-section">
				<div class="faq-heading section-inner">
					<span>ANTES DE EMPEZAR</span>
					<h2>Preguntas frecuentes</h2>
				</div>
				<div class="faq-list section-inner">
					{faqs.map((faq) => <details><summary><span>{faq.q}</span><b>+</b></summary><p>{faq.a}</p></details>)}
				</div>
			</section>

			<section class="final-section">
				<div class="final-card">
					<div class="final-grid" aria-hidden="true"></div>
					<div class="final-glow" aria-hidden="true"></div>
					<img src="/images/creattia/moki-mascot.webp" alt="" width="1254" height="1254" loading="lazy" />
					<div class="final-copy">
						<span>PROBALO CON TU MARCA</span>
						<h2>Tu próxima imagen<br />puede vender más.</h2>
						<p>Creá tu cuenta y generá 3 imágenes gratis. Sin tarjeta.</p>
						<a href="/app/" class="button button-primary">Empezar gratis <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg></a>
						<small>Google o email · Todo queda guardado</small>
					</div>
				</div>
			</section>
		</div>
	</main>

	<style>
		:global(html) { scroll-behavior: smooth; }
		:global(body) { margin: 0; background: #fff; color: #17151a; font-family: Inter, system-ui, sans-serif; }
		:global(a) { -webkit-tap-highlight-color: transparent; }
		main { overflow: hidden; }
		.section-inner { width: min(1120px, calc(100% - 40px)); margin-inline: auto; }
		.button { display: inline-flex; align-items: center; justify-content: center; gap: 11px; color: #fff; text-decoration: none; font-weight: 800; }
		.button svg, .plans-grid svg { width: 17px; height: 17px; fill: none; stroke: currentColor; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
		.button-primary { min-height: 58px; padding: 0 29px; border-radius: 15px; background: linear-gradient(135deg, #8755ef, #5b27c7); box-shadow: 0 19px 42px rgba(100, 45, 213, .27), inset 0 1px rgba(255, 255, 255, .25); font-size: 14px; transition: transform .2s ease, box-shadow .2s ease; }
		.button-primary:hover { transform: translateY(-3px); box-shadow: 0 25px 55px rgba(100, 45, 213, .35), inset 0 1px rgba(255, 255, 255, .25); }

		.nav-shell { position: absolute; z-index: 100; inset: 0 0 auto; background: transparent; }
		.nav-inner { width: min(1180px, calc(100% - 40px)); height: 82px; margin: auto; display: flex; align-items: center; justify-content: space-between; gap: 24px; }
		.brand { display: inline-flex; align-items: center; gap: 10px; color: #211d24; text-decoration: none; }
		.brand img { width: 50px; height: 50px; object-fit: contain; object-position: center; }
		.brand b { font-size: 17px; letter-spacing: -.025em; }
		.button-small { min-height: 46px; padding: 0 20px; border-radius: 13px; background: linear-gradient(135deg, #8250ea, #5c29c8); box-shadow: 0 13px 30px rgba(100, 49, 205, .2); font-size: 12px; transition: transform .2s ease, box-shadow .2s ease; }
		.button-small:hover { transform: translateY(-2px); box-shadow: 0 18px 36px rgba(100, 49, 205, .28); }

		.hero { position: relative; padding: 144px 0 92px; overflow: hidden; background: radial-gradient(circle at 76% 25%, rgba(173, 134, 255, .17), transparent 26%), linear-gradient(180deg, #fff, #faf7fd); }
		.hero-grid { position: absolute; inset: 0; opacity: .5; background-image: linear-gradient(rgba(111, 63, 205, .045) 1px, transparent 1px), linear-gradient(90deg, rgba(111, 63, 205, .045) 1px, transparent 1px); background-size: 40px 40px; mask-image: linear-gradient(#000, transparent 90%); }
		.hero-orb { position: absolute; border-radius: 50%; filter: blur(130px); pointer-events: none; }
		.hero-orb-one { width: 560px; height: 560px; left: -330px; top: -280px; background: #d2b8ff; opacity: .34; }
		.hero-orb-two { width: 390px; height: 390px; right: -160px; top: 500px; background: #e5c8ff; opacity: .25; }
		.hero-inner { position: relative; z-index: 2; width: min(1180px, calc(100% - 40px)); margin: auto; }
		.hero-copy { max-width: 1050px; margin: auto; text-align: center; }
		.eyebrow { display: inline-flex; align-items: center; gap: 9px; color: #7543da; font-size: 10px; font-weight: 850; letter-spacing: .16em; }
		.eyebrow i { width: 7px; height: 7px; border-radius: 50%; background: #8654e7; box-shadow: 0 0 0 6px rgba(134, 84, 231, .1); }
		.hero-copy h1 { max-width: 1040px; margin: 28px auto 24px; font-size: clamp(58px, 6.5vw, 92px); line-height: .95; letter-spacing: -.067em; text-wrap: balance; }
		.hero-copy h1 em { color: #7442dc; font-style: normal; }
		.hero-copy > p { max-width: 760px; margin: 0 auto; color: #68616b; font-size: 18px; line-height: 1.65; text-wrap: balance; }
		.hero-copy > p strong { color: #282329; }
		.hero-actions { display: flex; align-items: center; justify-content: center; gap: 20px; margin-top: 31px; }
		.hero-actions > span { color: #827a87; font-size: 12px; }
		.hero-actions > span b { color: #27a871; }
		.hero-showcase { position: relative; max-width: 1100px; margin: 60px auto 0; overflow: hidden; border: 1px solid rgba(116, 66, 220, .12); border-radius: 32px; background: rgba(255, 255, 255, .84); box-shadow: 0 38px 95px rgba(73, 43, 93, .14), 0 2px 0 rgba(255, 255, 255, .9) inset; backdrop-filter: blur(16px); }
		.showcase-video { position: relative; height: 710px; overflow: hidden; background: #f7f3fa; }
		.showcase-video video { width: 100%; height: 100%; display: block; object-fit: cover; object-position: center; }
		.hero-proof { max-width: 1020px; min-height: 83px; margin: 0 auto; padding: 0 34px; display: flex; align-items: center; justify-content: space-between; gap: 24px; border: 1px solid rgba(53, 40, 61, .09); border-top: 0; border-radius: 0 0 24px 24px; background: rgba(255, 255, 255, .7); }
		.hero-proof span { display: flex; flex-direction: column; gap: 5px; text-align: center; }
		.hero-proof strong { font-size: 13px; }
		.hero-proof small { color: #918996; font-size: 10px; }
		.hero-proof > i { width: 1px; height: 30px; background: rgba(52, 42, 60, .12); }

		.post-hero { font-family: 'Manrope Variable', Manrope, system-ui, sans-serif; font-variation-settings: 'wght' 500; }
		.post-hero h2, .post-hero h3, .post-hero strong, .post-hero b { font-variation-settings: 'wght' 760; }

		.bento-showcase { padding: 12px; background: #fff; }
		.bento-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
		.bento-card { position: relative; min-height: 650px; overflow: hidden; border-radius: 31px; background: #f1f2f4; }
		.bento-copy { position: relative; z-index: 5; padding: 51px 30px 0; text-align: center; }
