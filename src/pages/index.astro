---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import '@fontsource-variable/outfit';
import '@fontsource-variable/plus-jakarta-sans';

const plans = [
	{
		code: 'creator',
		name: 'Creator',
		price: 19,
		credits: 40,
		copy: 'Para crear contenido todas las semanas.',
		features: ['40 imágenes por mes', '1 marca conectada', 'Biblioteca completa', 'Historial y favoritos'],
	},
	{
		code: 'pro',
		name: 'Pro',
		price: 39,
		credits: 120,
		copy: 'Para probar más ideas y encontrar qué vende.',
		features: ['120 imágenes por mes', 'Hasta 3 marcas', 'Variaciones de imágenes', 'Prioridad de generación'],
		featured: true,
	},
	{
		code: 'scale',
		name: 'Scale',
		price: 79,
		credits: 300,
		copy: 'Para equipos con producción constante.',
		features: ['300 imágenes por mes', 'Hasta 10 marcas', 'Todo lo incluido en Pro', 'Uso para equipos'],
	},
];

const businessTypes = [
	['🛍️', 'E-commerce'],
	['🍽️', 'Gastronomía'],
	['👟', 'Moda'],
	['✨', 'Belleza'],
	['💪', 'Fitness'],
	['💼', 'Servicios'],
	['🖥️', 'Productos digitales'],
	['🚀', 'Apps y SaaS'],
];

const faqs = [
	{
		q: '¿Qué es Creattia?',
		a: 'Es una aplicación para generar imágenes de venta con tu marca y tus productos. Elegís una idea, completás unos pocos pasos y Creattia prepara la imagen por vos.',
	},
	{
		q: '¿Necesito saber diseñar o escribir prompts?',
		a: 'No. La experiencia está pensada para personas sin conocimientos de diseño ni inteligencia artificial. Creattia arma las instrucciones automáticamente.',
	},
	{
		q: '¿Cómo aprende mi marca?',
		a: 'Conectás tu web e Instagram una vez. Creattia analiza tu identidad y organiza tus productos para tenerlos disponibles cada vez que quieras crear.',
	},
	{
		q: '¿Puedo agregar una indicación propia?',
		a: 'Sí, pero es opcional. Si no escribís nada, Creattia usa la información de tu marca, el producto y la idea que elegiste.',
	},
	{
		q: '¿Puedo modificar una imagen ya creada?',
		a: 'Sí. Podés cambiar el producto, conservar el mismo ángulo o pedir una versión muy parecida, más libre o completamente nueva.',
	},
	{
		q: '¿Cómo funciona la prueba gratis?',
		a: 'Creás tu cuenta con Google o email y recibís 3 generaciones para probar el flujo completo. No necesitás tarjeta.',
	},
	{
		q: '¿Qué tipo de productos puedo usar?',
		a: 'Podés trabajar con productos físicos, servicios, gastronomía, moda, belleza, contenido digital y muchos otros tipos de negocio.',
	},
	{
		q: '¿Qué formatos puedo generar?',
		a: 'Podés elegir formatos cuadrados, verticales o para historias según dónde quieras usar la imagen.',
	},
];
---

<Layout
	title="Creattia | Imágenes con IA que venden"
	description="Elegí una idea, sumá tu producto y generá imágenes listas para vender con tu marca. Probá 3 generaciones gratis."
	ogTitle="Creattia | La plataforma N°1 para generar imágenes que venden"
	ogDescription="Generá anuncios y fotos de producto con tu marca, sin diseñar ni escribir prompts. Probá 3 imágenes gratis."
	ogImage="/images/creattia/moki-og.jpg"
	favicon="/images/creattia/moki-full-favicon-96.png"
	appleTouchIcon="/images/creattia/moki-full-apple-touch.png"
	manifest="/creattia.webmanifest"
	noindex={true}
>
	<header class="nav-shell">
		<nav class="nav-inner" aria-label="Navegación principal">
			<a href="#top" class="brand" aria-label="Creattia, volver al inicio">
				<img src="/images/creattia/moki-mascot.webp" alt="" width="1254" height="1254" />
				<b>Creattia</b>
			</a>
			<a href="/app/" class="nav-cta">Empezar gratis <span>→</span></a>
		</nav>
	</header>

	<main id="top">
		<section class="hero">
			<div class="hero-grid" aria-hidden="true"></div>
			<div class="hero-glow" aria-hidden="true"></div>
			<div class="hero-inner">
				<span class="hero-label">IMÁGENES CON IA PARA NEGOCIOS</span>
				<h1>La plataforma N°1 para generar <em>imágenes que venden.</em></h1>
				<p>Elegí una idea, sumá tu producto y creá una imagen lista para publicar. Sin diseñar ni escribir prompts.</p>
				<div class="hero-actions">
					<a href="/app/" class="primary-button">Crear 3 imágenes gratis <span>→</span></a>
					<small>Google o email · Sin tarjeta</small>
				</div>
				<div class="hero-video">
					<video autoplay muted loop playsinline preload="auto" poster="/videos/creattia-hero.jpg" aria-label="Creattia convierte un producto en una imagen lista para vender">
						<source src="/videos/creattia-hero.mp4" type="video/mp4" />
					</video>
				</div>
			</div>
		</section>

		<div class="reference-system">
			<section class="use-cases" aria-label="Qué podés crear con Creattia">
				<div class="use-grid">
					<article class="use-card">
						<header>
							<h2>Contenido para redes</h2>
							<p>Para que no pierdas tiempo pensando qué publicar.</p>
						</header>
						<div class="use-art social-art" data-prompt-id="01" aria-hidden="true">
							<div class="social-post post-a"><small>NUEVO</small><strong>20% OFF</strong><i></i></div>
							<div class="social-post post-b"><small>SOLO HOY</small><strong>ENVÍO GRATIS</strong><i></i></div>
							<div class="social-post post-c"><small>3 CUOTAS</small><strong>SIN INTERÉS</strong><i></i></div>
						</div>
					</article>

					<article class="use-card">
						<header>
							<h2>Imágenes para anuncios</h2>
							<p>Para probar más ángulos sin depender de una agencia.</p>
						</header>
						<div class="use-art ads-art" data-prompt-id="02" aria-hidden="true">
							<div class="ad-panel">
								<span>LANZAMIENTO</span>
								<strong>Tu producto.<br />Más deseable.</strong>
								<div class="ad-product"><i></i></div>
								<small>COMPRAR AHORA</small>
							</div>
						</div>
					</article>

					<article class="use-card">
						<header>
							<h2>Fotos de producto</h2>
							<p>Para mostrar lo que vendés con una imagen profesional.</p>
						</header>
						<div class="use-art product-art" data-prompt-id="03" aria-hidden="true">
							<div class="product-halo"></div>
							<div class="product-pedestal"></div>
							<div class="product-object"><i></i><b>CREATTIA</b></div>
							<span class="spark spark-one">✦</span>
							<span class="spark spark-two">✦</span>
						</div>
					</article>

					<article class="use-card use-card-dark">
						<header>
							<h2>Una biblioteca que crece</h2>
							<p>Para que siempre tengas una nueva idea para probar.</p>
						</header>
						<div class="use-art library-art" data-prompt-id="04" aria-hidden="true">
							<div class="library-glow"></div>
							<div class="library-card library-back">LANZAMIENTO</div>
							<div class="library-card library-mid">PROMOCIÓN</div>
							<div class="library-card library-front">ENVÍO GRATIS</div>
							<img src="/images/creattia/moki-mascot.webp" alt="" width="1254" height="1254" loading="lazy" />
						</div>
						<a href="/app/">Explorar ideas <span>→</span></a>
					</article>
				</div>
			</section>

			<section class="results-section">
				<div class="section-heading results-heading">
					<p>Una forma más simple de crear</p>
					<h2>Más ideas para probar.<br />Menos tiempo hasta publicar.</h2>
				</div>
				<div class="results-grid">
					<article class="result-card result-speed" data-prompt-id="05">
						<div class="result-art" aria-hidden="true">
							<span class="mini-chip chip-one">Elegí</span>
							<span class="mini-chip chip-two">Generá</span>
							<span class="mini-chip chip-three">Publicá</span>
							<div class="result-orb">✦</div>
						</div>
						<div>
							<small>MENOS PASOS</small>
							<h3>De la idea a la imagen en minutos.</h3>
						</div>
					</article>

					<article class="result-card result-brand" data-prompt-id="06">
						<div class="result-art" aria-hidden="true">
							<div class="brand-board">
								<span class="brand-color"></span><span class="brand-color"></span><span class="brand-color"></span>
								<b>Aa</b>
								<small>IDENTIDAD APLICADA</small>
							</div>
						</div>
						<div>
							<small>MISMA IDENTIDAD</small>
							<h3>Cada resultado se siente parte de tu marca.</h3>
						</div>
					</article>

					<article class="result-card result-versions" data-prompt-id="07">
						<div class="result-art" aria-hidden="true">
							<div class="version version-one"><b>20% OFF</b></div>
							<div class="version version-two"><b>ENVÍO GRATIS</b></div>
							<div class="version version-three"><b>NUEVO</b></div>
						</div>
						<div>
							<small>MÁS VARIANTES</small>
							<h3>Probá otros mensajes sin empezar de cero.</h3>
						</div>
					</article>
				</div>
			</section>

			<section class="how-section" id="como-funciona">
				<div class="section-heading">
					<h2>Cómo funciona</h2>
				</div>
				<div class="steps-grid">
					<article class="step-card">
						<div class="step-art connect-art" data-prompt-id="08" aria-hidden="true">
							<div class="orbit orbit-a"></div>
							<div class="orbit orbit-b"></div>
							<img src="/images/creattia/moki-mascot.webp" alt="" width="1254" height="1254" loading="lazy" />
							<span class="source source-web">↗ Web</span>
							<span class="source source-ig">◎ Instagram</span>
						</div>
						<div class="step-pill"><b>1</b><span>Conectá tu negocio y Creattia entiende tu marca.</span></div>
					</article>

					<article class="step-card">
						<div class="step-art choose-art" data-prompt-id="09" aria-hidden="true">
							<div class="choice choice-a"><small>OBJETIVO</small><b>Vender más</b></div>
							<div class="choice choice-b"><small>CATEGORÍA</small><b>Promociones</b></div>
							<div class="choice choice-c"><small>IDEA</small><b>Envío gratis</b><i>✓</i></div>
						</div>
						<div class="step-pill"><b>2</b><span>Elegí una idea, tu producto y el formato.</span></div>
					</article>

					<article class="step-card">
						<div class="step-art generate-art" data-prompt-id="10" aria-hidden="true">
							<div class="generate-glow"></div>
							<div class="generated-piece"><small>LISTO PARA PUBLICAR</small><strong>ENVÍO<br />GRATIS</strong><i></i></div>
							<span>✦</span>
						</div>
						<div class="step-pill"><b>3</b><span>Generá, descargá o pedí una nueva versión.</span></div>
					</article>
				</div>
			</section>

			<section class="formats-section">
				<div class="section-heading">
					<h2>Creá para los formatos<br />que tu negocio necesita</h2>
					<p>Elegís la proporción antes de generar. El resultado sale listo para usar donde quieras.</p>
				</div>
				<div class="formats-grid">
					<article>
						<div class="format-copy">
							<span class="meta-mark">∞</span>
							<div><h3>Feed y anuncios</h3><p>Cuadrado o vertical para tus campañas y publicaciones.</p></div>
						</div>
						<div class="format-preview feed-preview" data-prompt-id="11" aria-hidden="true"><div>1:1</div><div>4:5</div></div>
					</article>
					<article>
						<div class="format-copy">
							<span class="story-mark">◉</span>
							<div><h3>Historias y contenido vertical</h3><p>Formato 9:16 para ocupar toda la pantalla.</p></div>
						</div>
						<div class="format-preview story-preview" data-prompt-id="12" aria-hidden="true"><div>9:16</div><i>✦</i></div>
					</article>
				</div>
			</section>

			<section class="pricing-section" id="planes">
				<div class="pricing-aurora" aria-hidden="true"></div>
				<div class="section-heading pricing-heading">
					<h2>Precios simples</h2>
					<p>Elegí cuántas imágenes querés generar por mes.</p>
					<div class="billing-toggle"><b>Mensual</b><span>Cancelá cuando quieras</span></div>
				</div>
				<div class="plans-grid">
					{plans.map((plan) => (
						<article class:list={{ featured: plan.featured }}>
							{plan.featured && <span class="popular">MÁS ELEGIDO</span>}
							<header><h3>{plan.name}</h3><p>{plan.copy}</p></header>
							<div class="price"><small>USD</small><b>{plan.price}</b><span>/mes</span></div>
							<strong>{plan.credits} imágenes por mes</strong>
							<a href={'/app/?plan=' + plan.code}>Elegir {plan.name} <span>→</span></a>
							<ul>{plan.features.map((feature) => <li><i>✓</i>{feature}</li>)}</ul>
						</article>
					))}
				</div>
				<p class="trial-note">Primero probá 3 imágenes gratis. Sin tarjeta.</p>
			</section>

			<section class="business-section">
				<div class="business-marquee business-top" aria-label="Tipos de negocio">
					<div class="business-track">
						<div class="business-set">{businessTypes.map(([emoji, name]) => <span><i>{emoji}</i><b>{name}</b></span>)}</div>
						<div class="business-set" aria-hidden="true">{businessTypes.map(([emoji, name]) => <span><i>{emoji}</i><b>{name}</b></span>)}</div>
					</div>
				</div>
				<div class="business-heading">
					<h2>Funciona para cualquier<br />tipo de negocio</h2>
				</div>
				<div class="business-marquee business-bottom" aria-hidden="true">
					<div class="business-track">
						<div class="business-set">{[...businessTypes].reverse().map(([emoji, name]) => <span><i>{emoji}</i><b>{name}</b></span>)}</div>
						<div class="business-set" aria-hidden="true">{[...businessTypes].reverse().map(([emoji, name]) => <span><i>{emoji}</i><b>{name}</b></span>)}</div>
					</div>
				</div>
			</section>

			<section class="why-section">
				<div class="section-heading why-heading">
					<p>Pensada para vender sin complicarte</p>
					<h2>¿Por qué Creattia?</h2>
				</div>
				<div class="why-grid">
					<article class="why-main" data-prompt-id="13">
						<div class="why-art" aria-hidden="true">
							<div class="why-sphere"></div>
							<img src="/images/creattia/moki-mascot.webp" alt="" width="1254" height="1254" loading="lazy" />
						</div>
						<div class="why-copy">
							<small>CREAR SIN APRENDER IA</small>
							<h3>La tecnología trabaja por detrás. Vos solo elegís qué querés vender.</h3>
							<p>Sin prompts largos, configuraciones difíciles ni herramientas separadas.</p>
						</div>
					</article>
					<div class="why-stack">
						<article>
							<span>01</span>
							<div><h3>Tu marca queda lista</h3><p>Conectala una vez y reutilizá productos, estilo e información.</p></div>
						</article>
						<article>
							<span>02</span>
							<div><h3>Siempre podés iterar</h3><p>Volvé a una creación, cambiá algo y generá la siguiente versión.</p></div>
						</article>
						<article>
							<span>03</span>
							<div><h3>La biblioteca sigue creciendo</h3><p>Nuevas ideas, categorías y formatos para probar.</p></div>
						</article>
					</div>
				</div>
			</section>

			<section class="faq-section" id="faq">
				<div class="section-heading"><h2>Preguntas frecuentes</h2></div>
				<div class="faq-list">
					{faqs.map((faq) => (
						<details>
							<summary><span>{faq.q}</span><b>+</b></summary>
							<p>{faq.a}</p>
						</details>
					))}
				</div>
			</section>

			<section class="final-section" id="empezar">
				<div class="final-card" data-prompt-id="14">
					<div class="final-grid" aria-hidden="true"></div>
					<div class="final-light" aria-hidden="true"></div>
					<img src="/images/creattia/moki-mascot.webp" alt="" width="1254" height="1254" loading="lazy" />
					<div class="final-copy">
						<h2>¿Listo para crear imágenes que den ganas de comprar?</h2>
						<a href="/app/">Crear 3 imágenes gratis <span>→</span></a>
						<small>Google o email · Sin tarjeta</small>
					</div>
				</div>
			</section>
		</div>
	</main>

	<style>
		:global(html) { scroll-behavior: smooth; }
		:global(body) {
			margin: 0;
			background: #fff;
			color: #0d1522;
			font-family: 'Plus Jakarta Sans Variable', 'Plus Jakarta Sans', Arial, Helvetica, sans-serif;
			-webkit-font-smoothing: antialiased;
		}
		:global(*) { box-sizing: border-box; }
		:global(a) { -webkit-tap-highlight-color: transparent; }
		main { overflow: hidden; }
		.reference-system h2,
		.reference-system h3 {
			font-family: 'Outfit Variable', Outfit, Arial, Helvetica, sans-serif;
		}
		.reference-system h2,
		.reference-system h3,
		.reference-system p { margin-top: 0; }
		.section-heading { text-align: center; }
		.section-heading h2 {
			margin: 0;
			font-size: 48px;
			font-weight: 900;
			line-height: 1;
			letter-spacing: -.025em;
			text-wrap: balance;
		}
		.section-heading > p {
			margin: 0 0 14px;
			color: rgba(13, 21, 34, .42);
			font-size: 16px;
			line-height: 1.5;
		}

		.nav-shell { position: absolute; z-index: 50; inset: 0 0 auto; }
		.nav-inner {
			width: min(1180px, calc(100% - 40px));
			height: 82px;
			margin: auto;
			display: flex;
			align-items: center;
			justify-content: space-between;
		}
		.brand { display: inline-flex; align-items: center; gap: 9px; color: #0d1522; text-decoration: none; }
		.brand img { width: 50px; height: 50px; object-fit: contain; }
		.brand b { font-family: 'Outfit Variable', Outfit, sans-serif; font-size: 19px; font-weight: 800; letter-spacing: -.025em; }
		.nav-cta {
			min-height: 44px;
			padding: 0 18px;
			display: inline-flex;
			align-items: center;
			gap: 10px;
			border-radius: 999px;
			background: #0d1522;
			color: #fff;
			font-size: 12px;
			font-weight: 700;
			text-decoration: none;
			box-shadow: 0 8px 20px rgba(13, 21, 34, .14);
			transition: transform .2s ease;
		}
		.nav-cta:hover { transform: translateY(-2px); }

		.hero {
			position: relative;
			padding: 112px 0 12px;
			overflow: hidden;
			background: radial-gradient(circle at 72% 20%, rgba(170, 129, 255, .17), transparent 26%), linear-gradient(180deg, #fff, #faf8fc);
		}
		.hero-grid {
			position: absolute;
			inset: 0;
			opacity: .42;
			background-image: linear-gradient(rgba(111, 63, 205, .05) 1px, transparent 1px), linear-gradient(90deg, rgba(111, 63, 205, .05) 1px, transparent 1px);
			background-size: 42px 42px;
			mask-image: linear-gradient(#000, transparent 92%);
		}
		.hero-glow {
			position: absolute;
			width: 620px;
			height: 620px;
			left: -380px;
			top: -320px;
			border-radius: 50%;
			background: #cfb4ff;
			filter: blur(125px);
			opacity: .35;
		}
		.hero-inner { position: relative; z-index: 2; width: min(1180px, calc(100% - 40px)); margin: auto; text-align: center; }
		.hero-label { color: #7543da; font-size: 10px; font-weight: 800; letter-spacing: .16em; }
		.hero h1 {
			max-width: 800px;
			margin: 18px auto 16px;
			font-family: 'Outfit Variable', Outfit, sans-serif;
			font-size: clamp(42px, 4.5vw, 60px);
			font-weight: 900;
			line-height: .98;
			letter-spacing: -.05em;
			text-wrap: balance;
		}
		.hero h1 em { color: #7442dc; font-style: normal; }
		.hero > div > p {
			max-width: 615px;
			margin: 0 auto;
			color: rgba(13, 21, 34, .62);
			font-size: 15px;
			line-height: 1.6;
			text-wrap: balance;
		}
		.hero-actions { margin-top: 23px; display: flex; align-items: center; justify-content: center; gap: 16px; }
		.primary-button {
			min-height: 56px;
			padding: 0 26px;
			display: inline-flex;
			align-items: center;
			gap: 13px;
			border-radius: 14px;
			background: linear-gradient(135deg, #8755ef, #5b27c7);
			color: #fff;
			font-size: 14px;
			font-weight: 800;
			text-decoration: none;
			box-shadow: 0 18px 40px rgba(100, 45, 213, .25), inset 0 1px rgba(255, 255, 255, .25);
			transition: transform .2s ease, box-shadow .2s ease;
		}
		.primary-button:hover { transform: translateY(-3px); box-shadow: 0 24px 50px rgba(100, 45, 213, .32); }
		.hero-actions small { color: rgba(13, 21, 34, .48); font-size: 11px; }
		.hero-video {
			max-width: 820px;
			height: 500px;
			margin: 38px auto 0;
			overflow: hidden;
			border: 1px solid rgba(116, 66, 220, .12);
			border-radius: 24px;
			background: #f6f3f8;
			box-shadow: 0 30px 72px rgba(73, 43, 93, .13);
		}
		.hero-video video { width: 100%; height: 100%; display: block; object-fit: cover; }

