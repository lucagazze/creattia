---
export const prerender = true;
import Layout from '../layouts/Layout.astro';

const plans = [
	{ code: 'creator', name: 'Creator', price: 19, credits: 40, copy: 'Para crear contenido todas las semanas.', featured: false },
	{ code: 'pro', name: 'Pro', price: 39, credits: 120, copy: 'Para probar más ideas y anuncios.', featured: true },
	{ code: 'scale', name: 'Scale', price: 79, credits: 300, copy: 'Para equipos que producen a diario.', featured: false },
];

const categories = [
	{ title: 'Vender más', copy: 'Promos y ofertas para impulsar la compra.', color: '#ff7a59', branches: ['Promociones', 'Packs y volumen', 'Envío gratis', 'Cuotas'] },
	{ title: 'Generar confianza', copy: 'Reseñas y pruebas que reducen dudas.', color: '#9b7cf3', branches: ['Reseñas', 'Mensajes', 'UGC', 'Resultados'] },
	{ title: 'Convencer', copy: 'Comparaciones que facilitan la decisión.', color: '#ef646f', branches: ['Competencia', 'Valor y costo', 'Antes y después'] },
	{ title: 'Educar', copy: 'Contenido que explica por qué elegirte.', color: '#55a8ff', branches: ['Datos', 'Mitos', 'Preguntas', 'Storytelling'] },
	{ title: 'Mostrar producto', copy: 'Tu producto claro, atractivo y en contexto.', color: '#3fc68c', branches: ['Hero', 'Lifestyle', 'Detalle', 'Uso'] },
	{ title: 'Construir autoridad', copy: 'Credenciales e historias que dan respaldo.', color: '#e7b348', branches: ['Expertos', 'Certificaciones', 'Fundador'] },
];

const businessTypes = [
	{ name: 'E-commerce', color: '#a77bf7', icon: 'M3 4h2l2 10h10l2-7H6m3 12a1 1 0 1 0 0 .01M17 19a1 1 0 1 0 0 .01' },
	{ name: 'Gastronomía', color: '#ff9b63', icon: 'M7 3v7m-2-7v4a2 2 0 0 0 4 0V3M7 10v11m8-18c-2 3-2 7 1 9v9m0-9V3' },
	{ name: 'Moda', color: '#f27cb0', icon: 'M12 7a2 2 0 1 0-2-2m2 2v2L3 17h18L12 9' },
	{ name: 'Belleza', color: '#df8cff', icon: 'M12 3c3 4 5 7 5 10a5 5 0 0 1-10 0c0-3 2-6 5-10m6 1v4m-2-2h4' },
	{ name: 'Fitness', color: '#6ed5a1', icon: 'M4 9v6m3-8v10m10-10v10m3-8v6M7 12h10M2 11v2m20-2v2' },
	{ name: 'Servicios', color: '#75b7ff', icon: 'M9 6V4h6v2m-11 0h16v13H4zM4 11h16M9 11v2h6v-2' },
	{ name: 'Productos digitales', color: '#ffd16c', icon: 'M4 4h16v16H4zM4 8h16m-8 4 4 2.5-4 2.5z' },
	{ name: 'Apps y SaaS', color: '#8f95ff', icon: 'M5 4h5v5H5zm9 0h5v5h-5zM5 14h5v5H5zm9 0h5v5h-5z' },
];

const faqs = [
	{ q: '¿Es un pack de imágenes?', a: 'No. Es una aplicación con una biblioteca de ideas que crece y se actualiza dentro de tu cuenta.' },
	{ q: '¿Necesito saber diseñar o usar IA?', a: 'No. Elegís una idea, un producto y un formato. La aplicación resuelve el diseño y las instrucciones.' },
	{ q: '¿Cómo usa mi marca y mis productos?', a: 'Tu web, Instagram, colores, logo y catálogo quedan guardados en tu cuenta para cada nueva imagen.' },
	{ q: '¿Cómo funciona la prueba gratuita?', a: 'Creás tu cuenta y recibís 3 imágenes gratis. No necesitás tarjeta.' },
	{ q: '¿Qué incluye cada plan?', a: 'Toda la biblioteca, nuevas ideas, productos guardados, favoritos e historial. Solo cambia la cantidad de generaciones mensuales.' },
	{ q: '¿Puedo modificar una imagen generada?', a: 'Sí. Podés cambiar el producto, pedir un ajuste o crear una versión nueva usando la imagen anterior como referencia.' },
];
---

<Layout
	title="Creattia | Imágenes con IA que venden"
	description="Elegí una idea, sumá tu producto y generá imágenes listas para vender con tu marca. Probá 3 generaciones gratis."
	ogTitle="Creattia | La plataforma N°1 para generar imágenes que venden"
	ogDescription="Generá anuncios y fotos de producto con tu marca, sin diseñar ni escribir prompts. Probá 3 imágenes gratis."
	ogImage="/images/creattia/moki-og.jpg"
	favicon="/images/creattia/moki-favicon-96.png"
	appleTouchIcon="/images/creattia/moki-apple-touch.png"
	manifest="/creattia.webmanifest"
	noindex={true}
>
	<header class="nav-shell">
		<div class="nav-inner">
			<a href="#top" class="brand"><span><img src="/images/creattia/moki-favicon-96.png" alt="" /></span><b>Creattia</b></a>
			<a href="/app/" class="nav-cta"><span>Empezar gratis</span><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
		</div>
	</header>

	<main id="top">
		<section class="hero">
			<div class="hero-grid"></div><div class="hero-glow"></div>
			<div class="hero-inner">
				<div class="hero-copy">
					<span class="eyebrow"><i></i>IMÁGENES CON IA PARA NEGOCIOS</span>
					<h1>La plataforma N°1 para generar <em>imágenes que venden.</em></h1>
					<p>Elegí una idea, sumá tu producto y generá una imagen lista para publicar. <strong>Sin diseñar ni escribir prompts.</strong></p>
					<div class="hero-actions"><a href="/app/">Crear 3 imágenes gratis <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a><span><b>✓</b> Google o email · Sin tarjeta</span></div>
					<div class="hero-proof"><span><strong>Lista en minutos</strong><small>de producto a anuncio</small></span><i></i><span><strong>Tu marca lista</strong><small>sin volver a cargarla</small></span><i></i><span><strong>Nuevas ideas</strong><small>cada semana</small></span></div>
				</div>
				<div class="hero-conversion-visual">
					<video autoplay muted loop playsinline preload="auto" poster="/videos/creattia-hero.jpg" aria-label="Creattia transforma una foto de producto en una imagen lista para vender">
						<source src="/videos/creattia-hero.mp4" type="video/mp4" />
					</video>
				</div>
			</div>
			<div class="hero-bottom"><span>Ofertas que convierten</span><i></i><span>Producto &amp; lifestyle</span><i></i><span>Prueba social</span><i></i><span>Ads listos para publicar</span></div>
		</section>

		<section class="living-library" id="biblioteca">
			<div class="section-inner split-heading">
				<div><span class="section-kicker">UNA BIBLIOTECA QUE NO PARA DE CRECER</span><h2>Siempre tenés una nueva idea<br/><em>para vender mejor.</em></h2></div>
				<p>Encontrá la imagen que necesitás por objetivo, elegila y adaptala a tu producto y a tu marca en minutos.</p>
			</div>
			<div class="category-grid section-inner">
				{categories.map((category, index) => <article style={`--accent:${category.color}`}><header><span>{String(index + 1).padStart(2,'0')}</span><i></i></header><h3>{category.title}</h3><p>{category.copy}</p><div>{category.branches.map((branch) => <span>{branch}<b>›</b></span>)}</div></article>)}
			</div>
			<div class="taxonomy-demo section-inner">
				<div class="taxonomy-copy"><span class="section-kicker">ENCONTRÁ TODO RÁPIDO</span><h3>La idea exacta.<br/>En pocos clics.</h3><p>Elegí objetivo, categoría y tipo. También podés buscar por nombre o guardar tus favoritas.</p></div>
				<div class="taxonomy-path"><div><small>1 · OBJETIVO</small><strong>Vender más</strong></div><i>→</i><div><small>2 · CATEGORÍA</small><strong>Promociones</strong></div><i>→</i><div><small>3 · TIPO</small><strong>Envío gratis</strong></div><span>✓</span></div>
			</div>
		</section>

		<section class="how" id="como-funciona">
			<div class="section-inner"><div class="center-heading"><span class="section-kicker">CREÁ SIN SABER DISEÑO</span><h2>De una idea a una imagen lista.<br/>En minutos.</h2><p>Moki te guía paso a paso. Vos elegís; la IA resuelve el resto.</p></div>
				<div class="steps">
					<article><span>01</span><div class="step-icon">⌕</div><h3>Elegí qué querés lograr</h3><p>Buscá por objetivo y encontrá una idea lista para usar.</p></article>
					<article><span>02</span><div class="step-icon">◇</div><h3>Sumá tu producto</h3><p>Elegilo de tu catálogo o subí una foto en el momento.</p></article>
					<article><span>03</span><div class="step-icon">✦</div><h3>Generá, ajustá y publicá</h3><p>Descargá la imagen o pedí una nueva versión en segundos.</p></article>
				</div>
			</div>
		</section>

		<section class="memory-section">
			<div class="section-inner memory-grid">
				<div class="memory-copy"><span class="section-kicker">TODO LISTO PARA LA PRÓXIMA</span><h2>Cargá tu marca una vez.<br/><em>Creá más rápido siempre.</em></h2><p>Tu web, productos, favoritos e imágenes quedan guardados en tu cuenta.</p><ul><li><b>✓</b><span><strong>Tus favoritas</strong><small>Guardá ideas y encontralas al instante.</small></span></li><li><b>✓</b><span><strong>Tus últimas imágenes</strong><small>Reutilizalas o pedí una nueva versión.</small></span></li><li><b>✓</b><span><strong>Nuevas ideas</strong><small>Aparecen automáticamente en tu biblioteca.</small></span></li></ul></div>
			</div>
		</section>

		<section class="business-section">
			<div class="section-inner business-heading"><span class="section-kicker">HECHO PARA NEGOCIOS REALES</span><h2>Si tenés algo para vender,<br/><em>tenés algo para crear.</em></h2><p>Funciona con productos, servicios y negocios de cualquier rubro. Sin diseño ni experiencia en IA.</p></div>
			<div class="business-marquee" aria-label="Tipos de negocio compatibles">
				<div class="business-track">
					<div class="business-set">{businessTypes.map((business) => <span style={`--business-accent:${business.color}`}><i><svg viewBox="0 0 24 24" aria-hidden="true"><path d={business.icon}/></svg></i><b>{business.name}</b></span>)}</div>
					<div class="business-set" aria-hidden="true">{businessTypes.map((business) => <span style={`--business-accent:${business.color}`}><i><svg viewBox="0 0 24 24" aria-hidden="true"><path d={business.icon}/></svg></i><b>{business.name}</b></span>)}</div>
				</div>
			</div>
		</section>

		<section class="plans-section" id="planes">
			<div class="section-inner"><div class="center-heading"><span class="section-kicker">3 IMÁGENES GRATIS. SIN TARJETA.</span><h2>Elegí el plan que acompaña tu ritmo.</h2><p>Solo cambia la cantidad de generaciones. Todo lo demás está incluido.</p></div>
				<div class="plans-grid">{plans.map((plan) => <article class:list={{featured:plan.featured}}>{plan.featured && <span class="popular">MÁS ELEGIDO</span>}<small>PLAN {plan.name.toUpperCase()}</small><h3><b>USD</b>{plan.price}<em>/mes</em></h3><p>{plan.copy}</p><strong>{plan.credits} generaciones por mes</strong><ul><li>✓ Todas las ideas y actualizaciones</li><li>✓ Marca y catálogo siempre listos</li><li>✓ Historial, favoritos y ajustes</li></ul><a href={`/app/?plan=${plan.code}`}>Elegir {plan.name}<svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a></article>)}</div>
				<p class="plan-note">Probá primero tus 3 imágenes gratis. Elegí un plan cuando quieras seguir.</p>
			</div>
		</section>

		<section class="faq-section"><div class="section-inner faq-grid"><div><span class="section-kicker">PREGUNTAS FRECUENTES</span><h2>Todo claro antes de empezar.</h2><p>Si sabés elegir una foto, ya sabés usar la aplicación.</p></div><div>{faqs.map((faq) => <details><summary><span>{faq.q}</span><b>+</b></summary><p>{faq.a}</p></details>)}</div></div></section>

		<section class="final-section"><div class="final-card section-inner"><div class="final-moki"><img src="/images/creattia/moki-mascot.webp" alt="" width="1254" height="1254" loading="lazy"/></div><div><span class="section-kicker">PROBALO CON TU MARCA</span><h2>Creá tu primera imagen ahora.</h2><p>Tenés 3 imágenes gratis para probar todo el flujo. Sin tarjeta.</p><a href="/app/">Crear 3 imágenes gratis <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a><small>Google o email · Sin tarjeta · Todo queda guardado</small></div></div></section>
	</main>

	<style>
		:global(html){scroll-behavior:smooth} :global(body){margin:0;background:#fff;color:#1b181e;font-family:Inter,system-ui,sans-serif}.nav-shell{position:absolute;z-index:100;top:0;left:0;right:0;background:transparent;border:0}.nav-inner{max-width:1180px;height:76px;margin:auto;padding:0 22px;display:flex;align-items:center;justify-content:space-between;gap:30px}.brand{display:flex;align-items:center;gap:9px;color:#241f27;text-decoration:none}.brand>span{width:34px;height:34px;display:grid;place-items:center;border-radius:10px;background:#211d24}.brand img{width:22px;height:22px;filter:invert(1)}.brand b{font-size:14px}.brand small{padding-left:10px;border-left:1px solid rgba(36,31,39,.12);color:#7850c2;font-size:7px;font-weight:800;letter-spacing:.14em;text-transform:uppercase}.nav-cta{height:45px;padding:0 21px;display:flex;align-items:center;gap:10px;border-radius:13px;background:linear-gradient(135deg,#7c4dea,#5d2ac8);color:#fff;text-decoration:none;font-size:10px;font-weight:800;box-shadow:0 13px 30px rgba(100,49,205,.22);transition:transform .2s ease,box-shadow .2s ease}.nav-cta:hover{transform:translateY(-2px);box-shadow:0 18px 38px rgba(100,49,205,.3)}.nav-cta svg,.hero-actions svg,.plans-grid svg,.final-card svg{width:15px;height:15px;fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
		main{overflow:hidden}.section-inner{width:min(1120px,calc(100% - 40px));margin-inline:auto}.hero{position:relative;min-height:850px;padding:126px 0 0;overflow:hidden;background:radial-gradient(circle at 78% 30%,rgba(170,129,255,.17),transparent 28%),linear-gradient(180deg,#fff,#faf7fd);color:#211d24}.hero-grid{position:absolute;inset:0;opacity:.42;background-image:linear-gradient(rgba(111,63,205,.045) 1px,transparent 1px),linear-gradient(90deg,rgba(111,63,205,.045) 1px,transparent 1px);background-size:35px 35px;mask-image:linear-gradient(#000,transparent 86%)}.hero-glow{position:absolute;width:660px;height:660px;left:-260px;top:-430px;border-radius:50%;background:#d4bcff;filter:blur(150px);opacity:.32}.hero-inner{position:relative;z-index:2;width:min(1180px,calc(100% - 40px));margin:auto;display:grid;grid-template-columns:.93fr 1.07fr;align-items:center;gap:24px}.eyebrow,.section-kicker{display:inline-flex;align-items:center;gap:9px;color:#7446d0;font-size:8px;font-weight:850;letter-spacing:.17em}.eyebrow i{width:6px;height:6px;border-radius:50%;background:#8553e6;box-shadow:0 0 0 5px rgba(133,83,230,.1)}.hero-copy h1{max-width:680px;margin:25px 0 22px;font-size:clamp(46px,5.2vw,70px);line-height:.98;letter-spacing:-.06em}.hero-copy h1 em,.split-heading h2 em,.memory-copy h2 em{color:#7442dc;font-style:normal}.hero-copy>p{max-width:590px;margin:0;color:#67616b;font-size:15px;line-height:1.7}.hero-copy>p strong{color:#282329;font-weight:680}.hero-actions{display:flex;align-items:center;gap:20px;margin-top:31px}.hero-actions>a,.final-card a{height:58px;padding:0 27px;display:inline-flex;align-items:center;gap:11px;border-radius:14px;background:linear-gradient(135deg,#7e4ee9,#5926c3);color:#fff;text-decoration:none;font-size:11px;font-weight:850;box-shadow:0 18px 42px rgba(100,45,213,.28),inset 0 1px rgba(255,255,255,.25);transition:transform .2s ease,box-shadow .2s ease}.hero-actions>a:hover{transform:translateY(-3px);box-shadow:0 25px 52px rgba(100,45,213,.36),inset 0 1px rgba(255,255,255,.25)}.hero-actions>span{color:#827a87;font-size:9px}.hero-actions>span b{color:#27a871}.hero-proof{display:flex;align-items:center;gap:18px;margin-top:34px}.hero-proof span{display:flex;flex-direction:column;gap:3px}.hero-proof strong{font-size:11px}.hero-proof small{color:#938b97;font-size:7px}.hero-proof i{width:1px;height:27px;background:rgba(52,42,60,.12)}
		.hero-conversion-visual{position:relative;height:575px;overflow:hidden;border:1px solid rgba(116,66,220,.1);border-radius:34px;background:#faf6fc;box-shadow:0 35px 80px rgba(73,43,93,.12)}.hero-conversion-visual video{width:100%;height:100%;display:block;object-fit:cover;object-position:center}.hero-bottom{position:absolute;z-index:3;left:50%;bottom:0;width:min(1120px,calc(100% - 40px));height:72px;display:flex;align-items:center;justify-content:center;gap:22px;border-top:1px solid rgba(50,40,57,.09);transform:translateX(-50%);color:#8c8490;font-size:8px;font-weight:750;letter-spacing:.06em}.hero-bottom i{width:4px;height:4px;border-radius:50%;background:#7a4ed0}
