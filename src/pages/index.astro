---
export const prerender = true;
import '@fontsource-variable/manrope';
import Layout from '../layouts/Layout.astro';

const examples = [
	{ image: '/images/creattia/reference-library/18-envio-gratis.png', label: 'Envío gratis' },
	{ image: '/images/creattia/reference-library/17-2x1-3x2.png', label: '3x2 y 2x1' },
	{ image: '/images/creattia/reference-library/22-cuotas-sin-interes.png', label: 'Cuotas sin interés' },
	{ image: '/images/creattia/reference-library/02-resena-5-estrellas.png', label: 'Reseñas' },
	{ image: '/images/creattia/reference-library/23-nosotros-vs-ellos.png', label: 'Comparativas' },
	{ image: '/images/creattia/reference-library/40-hero-limpio.png', label: 'Producto' },
	{ image: '/images/creattia/reference-library/30-listicle.png', label: 'Listas' },
	{ image: '/images/creattia/reference-library/42-lifestyle-en-uso.png', label: 'Lifestyle' },
];

const steps = [
	{ number: '01', title: 'Pegá tu URL', copy: 'Creattia analiza tu negocio, tu identidad y la información de tus productos.', visual: 'url' },
	{ number: '02', title: 'Elegí una idea', copy: 'Explorá categorías y encontrá la estructura que mejor encaja con lo que querés vender.', visual: 'idea' },
	{ number: '03', title: 'Sumá tu producto', copy: 'Usá uno, combiná varios o creá una comunicación general de tu marca.', visual: 'product' },
	{ number: '04', title: 'Generá y publicá', copy: 'Recibí entre una y cuatro imágenes. Descargalas o creá una nueva variante.', visual: 'result' },
];

const toolTabs = [
	{ id: 'ads', label: 'Anuncios', eyebrow: 'ANUNCIOS DE VENTA', title: 'Imágenes pensadas para detener el scroll.', copy: 'Partí de una estructura clara, aplicá tu producto y generá piezas listas para campañas.', image: '/images/creattia/reference-library/18-envio-gratis.png', bullets: ['Ofertas y urgencia', 'Cuotas y beneficios', 'Formatos para Meta Ads'] },
	{ id: 'promos', label: 'Promociones', eyebrow: 'PROMOCIONES', title: 'Hacé que la oferta se entienda en un segundo.', copy: '3x2, envío gratis, descuentos, bundles, regalos y más ángulos listos para adaptar.', image: '/images/creattia/reference-library/17-2x1-3x2.png', bullets: ['3x2 y 2x1', 'Precio tachado', 'Regalo con compra'] },
	{ id: 'product', label: 'Producto', eyebrow: 'FOTOS DE PRODUCTO', title: 'Tu producto como verdadero protagonista.', copy: 'Creá imágenes limpias, comparativas, despieces y escenas de uso sin empezar desde cero.', image: '/images/creattia/reference-library/43-despiece.png', bullets: ['Hero de e-commerce', 'Lifestyle', 'Qué viene en la caja'] },
	{ id: 'content', label: 'Contenido', eyebrow: 'CONTENIDO ORGÁNICO', title: 'Explicá, educá y construí confianza.', copy: 'Convertí beneficios, preguntas y reseñas en piezas visuales fáciles de entender.', image: '/images/creattia/reference-library/32-mito-vs-realidad.png', bullets: ['Mito vs. realidad', 'Listas y tutoriales', 'Prueba social'] },
];

const categories = ['Envío gratis', '3x2', 'Cuotas', 'Antes y después', 'Reseñas', 'UGC', 'Comparativas', 'Bundles', 'Lanzamientos', 'Listas', 'Mitos', 'Preguntas', 'Lifestyle', 'Despiece', 'Garantías'];
const businesses = ['E-commerce', 'Gastronomía', 'Moda', 'Belleza', 'Fitness', 'Servicios', 'Productos digitales', 'Apps y SaaS'];

const comparison = [
	{ label: 'Ideas de venta organizadas', creattia: true, chat: false, manual: false },
	{ label: 'Usa tu producto y tu marca', creattia: true, chat: 'Parcial', manual: true },
	{ label: 'No requiere escribir prompts', creattia: true, chat: false, manual: true },
	{ label: 'Genera de 1 a 4 variantes', creattia: true, chat: 'Parcial', manual: false },
	{ label: 'Historial, favoritos y reutilización', creattia: true, chat: false, manual: false },
];

const plans = [
	{ name: 'Gratis', price: '0', note: 'Para conocer todo el flujo.', credits: '3 imágenes', cta: 'Probar gratis', href: '/app/?plan=free', features: ['1 marca', 'Biblioteca completa', 'Sin tarjeta'] },
	{ name: 'Creator', price: '19', note: 'Para crear todas las semanas.', credits: '40 imágenes/mes', cta: 'Elegir Creator', href: '/app/?plan=creator', features: ['1 marca', 'Historial y favoritos', 'Variaciones de imágenes'] },
	{ name: 'Pro', price: '39', note: 'Para probar más ideas cada mes.', credits: '120 imágenes/mes', cta: 'Elegir Pro', href: '/app/?plan=pro', features: ['1 marca', 'Hasta 5 productos', 'Biblioteca completa'], featured: true },
	{ name: 'Scale', price: '79', note: 'Para trabajar a gran volumen.', credits: '300 imágenes/mes', cta: 'Elegir Scale', href: '/app/?plan=scale', features: ['1 marca', 'Hasta 5 productos', 'Más volumen mensual'] },
];

const faqs = [
	{ q: '¿Qué hace Creattia?', a: 'Convierte tu web, tus productos y una estructura de referencia en imágenes publicitarias estáticas listas para usar.' },
	{ q: '¿Necesito saber diseñar o usar inteligencia artificial?', a: 'No. Elegís una idea, el producto, el formato y cuántas variantes querés. Creattia se ocupa del resto.' },
	{ q: '¿Puedo usar más de un producto?', a: 'Sí. Podés elegir un producto, combinar varios o generar una pieza general de tu negocio.' },
	{ q: '¿Puedo cambiar una imagen ya generada?', a: 'Sí. Podés reutilizarla como referencia, cambiar el producto o el texto y decidir cuánto querés que varíe.' },
	{ q: '¿Qué formatos puedo crear?', a: 'Formatos verticales, cuadrados y apaisados para anuncios, redes sociales y tiendas online.' },
	{ q: '¿La prueba gratis necesita tarjeta?', a: 'No. Creás tu cuenta y recibís tres imágenes para probar el flujo completo.' },
];
---

<Layout
	title="Creattia | Creá imágenes que venden"
	description="Convertí tu web y tus productos en imágenes publicitarias listas para vender. Sin diseñar ni escribir prompts."
	ogTitle="Creattia | Imágenes publicitarias con IA"
	ogDescription="Elegí una idea, sumá tu producto y generá imágenes listas para publicar."
	ogImage="/images/creattia/moki-og.jpg"
>
	<header class="site-header" aria-label="Navegación principal">
		<a class="brand" href="#inicio" aria-label="Creattia, volver al inicio">
			<img src="/images/creattia/moki-mascot.webp" alt="" width="1254" height="1254" />
			<strong>Creattia</strong>
		</a>
		<nav>
			<a href="#como-funciona">Cómo funciona</a>
			<a href="#biblioteca">Biblioteca</a>
			<a href="#precios">Precios</a>
			<a href="/app/">Ingresar</a>
		</nav>
		<a class="header-cta" href="/app/">Empezar gratis <span>→</span></a>
	</header>

	<main>
		<section class="hero" id="inicio">
			<div class="hero-copy">
				<span class="rainbow-pill">IA PARA IMÁGENES PUBLICITARIAS</span>
				<h1>Creá más anuncios.<br /><em>Encontrá antes el que vende.</em></h1>
				<p>Creattia convierte tu web y tus productos en imágenes listas para publicar. Sin diseñar, sin escribir prompts y sin empezar de cero.</p>
				<a class="primary-cta" href="/app/">Crear 3 imágenes gratis <span>→</span></a>
				<div class="hero-facts" aria-label="Beneficios principales">
					<div><b>50</b><span>estructuras iniciales</span></div>
					<div><b>1–4</b><span>variantes por creación</span></div>
					<div><b>1 vez</b><span>cargás tu marca</span></div>
				</div>
			</div>
			<div class="hero-video-wrap">
				<div class="hero-orbit orbit-one"></div><div class="hero-orbit orbit-two"></div>
				<video autoplay muted loop playsinline preload="metadata" poster="/videos/creattia-hero 2.jpg" aria-label="Creattia convierte un producto en una imagen lista para vender">
					<source src="/videos/creattia-hero-4x3.mp4" type="video/mp4" />
				</video>
				<div class="video-chip chip-top"><i></i> Tu marca aplicada</div>
				<div class="video-chip chip-bottom">Producto → anuncio <b>en minutos</b></div>
			</div>
			<div class="hero-proof"><span class="proof-avatars"><i>M</i><i>C</i><i>✦</i></span><p><strong>3 imágenes gratis</strong><br />para probar el flujo completo</p></div>
		</section>

		<section class="work-showcase" id="biblioteca">
			<div class="section-title split-title">
				<h2>Probablemente ya viste anuncios así.</h2>
				<h2>Ahora podés crearlos con tu producto.</h2>
			</div>
			<div class="example-window" aria-label="Ejemplos de imágenes publicitarias">
				<div class="example-track">
					{[...examples, ...examples].map((item, index) => (
						<a href="/app/" class:list={{ 'example-card': true, raised: index % 3 === 1 }} aria-label={`Crear ${item.label}`}>
							<img src={item.image} alt={`Ejemplo de ${item.label}`} width="1080" height="1350" loading={index < examples.length ? 'eager' : 'lazy'} decoding="async" />
							<span>{item.label}<b>↗</b></span>
						</a>
					))}
				</div>
			</div>
			<a class="text-link" href="/app/">Ver todas las ideas <span>→</span></a>
		</section>

		<section class="manifesto">
			<div class="manifesto-copy">
				<p>En Creattia estamos cambiando cómo los negocios <em>crean imágenes.</em></p>
				<p>La IA entiende tu marca, tus productos y el objetivo de venta.</p>
				<p>Así hacés el trabajo de un equipo creativo, <em>sin contratar uno.</em></p>
			</div>
			<div class="manifesto-moki" aria-hidden="true"><span>✦</span><img src="/images/creattia/moki-mascot.webp" alt="" width="1254" height="1254" loading="lazy" /></div>
		</section>

		<section class="how" id="como-funciona">
			<div class="section-heading centered">
				<span>CÓMO FUNCIONA</span>
				<h2>De tu web a una imagen lista para vender.</h2>
				<p>Un flujo simple, guiado y pensado para quien no sabe diseñar.</p>
			</div>
			<div class="steps-grid">
				{steps.map((step) => (
					<article class="step-card">
						<header><b>{step.number}</b><span>PASO</span></header>
						<h3>{step.title}</h3><p>{step.copy}</p>
						<div class:list={{ 'step-visual': true, [step.visual]: true }} aria-hidden="true">
							{step.visual === 'url' && <><label>URL DE TU NEGOCIO</label><div><span>https://tumarca.com</span><b>→</b></div><small><i></i> Analizando identidad y productos…</small></>}
							{step.visual === 'idea' && <><span class="idea-chip">OFERTAS</span><div class="mini-ideas"><i>3x2</i><i>ENVÍO<br/>GRATIS</i><i>CUOTAS</i></div></>}
							{step.visual === 'product' && <><div class="product-stack"><span></span><span></span><span></span></div><small>3 productos seleccionados</small></>}
							{step.visual === 'result' && <><img src="/images/creattia/reference-library/18-envio-gratis.png" alt="" width="1080" height="1350" loading="lazy"/><div><span>Descargar</span><span>Nueva variante</span></div></>}
						</div>
					</article>
				))}
			</div>
	</section>

		<section class="toolkit">
			<div class="section-heading centered">
				<span>TODO EN UN SOLO LUGAR</span>
				<h2>Una plataforma para todas tus imágenes.</h2>
				<p>Elegí qué querés comunicar. Creattia te muestra el mejor punto de partida.</p>
			</div>
			<div class="tool-tabs" role="tablist" aria-label="Tipos de imágenes">
				{toolTabs.map((tab, index) => <button type="button" role="tab" data-tool-tab={tab.id} aria-selected={index === 0 ? 'true' : 'false'} class:list={{ active: index === 0 }}>{tab.label}</button>)}
			</div>
			<div class="tool-panels">
				{toolTabs.map((tab, index) => (
					<article data-tool-panel={tab.id} hidden={index !== 0}>
						<div class="tool-copy"><span>{tab.eyebrow}</span><h3>{tab.title}</h3><p>{tab.copy}</p><ul>{tab.bullets.map((bullet) => <li><i>✓</i>{bullet}</li>)}</ul><a href="/app/">Crear una imagen <b>→</b></a></div>
						<div class="tool-visual"><div class="tool-glow"></div><img src={tab.image} alt={`Ejemplo de ${tab.label}`} width="1080" height="1350" loading="lazy"/><span>LISTA PARA PUBLICAR</span></div>
					</article>
				))}
			</div>
		</section>

		<section class="brand-dna">
			<div class="brand-dna-head"><span>IMPULSADA POR</span><h2>El ADN de tu marca.</h2><p>Creattia aprende lo que hace reconocible a tu negocio y lo aplica en cada nueva imagen.</p></div>
			<div class="dna-layout">
				<div class="dna-core" aria-hidden="true"><div class="dna-orbit"></div><img src="/images/creattia/moki-mascot.webp" alt="" width="1254" height="1254" loading="lazy"/><span>MARCA<br/>CONECTADA</span></div>
				<div class="dna-cards">
					<article><b>01</b><h3>Reconoce tu estilo</h3><p>Colores, tono, identidad y forma de presentar tus productos.</p></article>
					<article><b>02</b><h3>Entiende qué vendés</h3><p>Analiza productos, beneficios, precios y argumentos comerciales.</p></article>
					<article><b>03</b><h3>Reutiliza lo aprendido</h3><p>Tu negocio queda listo para crear sin cargar todo otra vez.</p></article>
					<article><b>04</b><h3>Mantiene tus datos privados</h3><p>Tu información se usa únicamente para producir tus resultados.</p></article>
				</div>
			</div>
		</section>

		<section class="businesses">
			<div class="section-heading centered"><span>HECHA PARA NEGOCIOS REALES</span><h2>Funciona para cualquier tipo de negocio.</h2></div>
			<div class="business-marquee"><div class="business-track">{[...businesses, ...businesses].map((business, index) => <span><i>{String((index % businesses.length) + 1).padStart(2, '0')}</i>{business}<b>↗</b></span>)}</div></div>
		</section>

		<section class="library-depth">
			<div class="library-copy"><span>IDEAS SIEMPRE DISPONIBLES</span><h2>Llená tu calendario de anuncios con meses de anticipación.</h2><p>Guardá ideas, descartá las que no encajan y volvé a usar lo que ya funcionó. Como una biblioteca pensada para decidir rápido.</p><a href="/app/">Explorar la biblioteca <b>→</b></a></div>
			<div class="library-device">
				<div class="device-head"><span>Creattia</span><small>12 de 50</small></div>
				<div class="device-card"><img src="/images/creattia/reference-library/23-nosotros-vs-ellos.png" alt="Ejemplo de comparativa" width="1080" height="1350" loading="lazy"/><button aria-label="Guardar idea">♡</button></div>
				<div class="device-actions"><i>×</i><span>Guardar o usar</span><b>♥</b></div>
				<div class="device-moki"><img src="/images/creattia/moki-mascot.webp" alt="" width="1254" height="1254" loading="lazy"/><span>Elegí la que mejor encaja.</span></div>
			</div>
			<div class="category-cloud" aria-label="Categorías disponibles">{[...categories, ...categories].map((category) => <span>{category}</span>)}</div>
		</section>

		<section class="library-intelligence">
			<div class="section-heading centered"><span>BIBLIOTECA CREATTIA</span><h2>No es una caja vacía.<br/>Ya sabés por dónde empezar.</h2><p>Cada categoría te ayuda a encontrar una estructura útil según tu objetivo.</p></div>
			<div class="intelligence-grid">
				<div class="intelligence-collage">
					{examples.slice(0, 6).map((item) => <img src={item.image} alt={item.label} width="1080" height="1350" loading="lazy" />)}
				</div>
				<div class="intelligence-copy"><span>ESTRUCTURAS VISUALES</span><h3>Una biblioteca que se vuelve más útil con cada nueva idea.</h3><p>Ofertas, prueba social, producto, educación y comparativas organizadas para que encuentres rápido lo que necesitás.</p><div class="stats"><div><b>50</b><small>ideas iniciales</small></div><div><b>6</b><small>familias principales</small></div><div><b>1–4</b><small>resultados por creación</small></div></div></div>
			</div>
		</section>

		<section class="channels">
			<div class="section-heading centered"><span>LISTA PARA TU ECOSISTEMA</span><h2>Una imagen. Todos tus canales.</h2><p>Generá en el formato correcto y publicá donde ya vendés.</p></div>
			<div class="channel-grid">
				<article><i class="meta-mark">∞</i><h3>Meta Ads</h3><p>Campañas de conversión y remarketing.</p></article>
				<article><i class="instagram-mark">◎</i><h3>Instagram</h3><p>Feed, historias y formatos verticales.</p></article>
				<article><i class="facebook-mark">f</i><h3>Facebook</h3><p>Anuncios y publicaciones de venta.</p></article>
				<article><i class="shop-mark">↗</i><h3>Tu tienda</h3><p>Banners, productos y promociones.</p></article>
			</div>
		</section>

		<section class="comparison">
			<div class="section-heading centered"><span>MENOS HERRAMIENTAS. MÁS CLARIDAD.</span><h2>Todo lo necesario para crear estáticos.</h2><p>Sin saltar entre prompts, editores, carpetas y referencias.</p></div>
			<div class="comparison-table" role="table" aria-label="Comparación de herramientas">
				<div class="comparison-row comparison-head" role="row"><span></span><b>Creattia</b><b>Chat generalista</b><b>Editor manual</b></div>
				{comparison.map((row) => <div class="comparison-row" role="row"><strong>{row.label}</strong>{[row.creattia, row.chat, row.manual].map((value, index) => <span class:list={{ positive: value === true, creattia: index === 0 }}>{value === true ? '✓' : value === false ? '—' : value}</span>)}</div>)}
			</div>
		</section>

		<section class="privacy">
			<div class="privacy-grid"></div><div class="privacy-light"></div>
			<div class="privacy-copy"><span>PRIVACIDAD DESDE EL DISEÑO</span><h2>Tu marca es tuya.<br/>Tus productos también.</h2><p>La información que conectás se usa para generar tus imágenes y mantener tu espacio organizado.</p><div><i>✓</i><span><b>Espacio privado</b><small>Solo vos accedés a tus productos e imágenes.</small></span></div><div><i>✓</i><span><b>Datos separados</b><small>Cada cuenta trabaja con su propia biblioteca.</small></span></div></div>
			<div class="privacy-lock" aria-hidden="true"><span>✦</span><b>100%</b><small>TU ESPACIO</small></div>
		</section>

		<section class="for-people">
			<div class="section-heading centered"><span>PARA QUIEN ESTÁ HACIENDO EL TRABAJO</span><h2>Creada para vender más.<br/>No para aprender otra herramienta.</h2></div>
			<div class="people-grid">
				<article><span>01</span><h3>Dueños de e-commerce</h3><p>Convertí ofertas y productos en anuncios sin depender de un diseñador para cada idea.</p><small>PRODUCTO → CAMPAÑA</small></article>
				<article><span>02</span><h3>Equipos de marketing</h3><p>Probá más ángulos, iterá rápido y mantené una identidad coherente en cada pieza.</p><small>IDEA → VARIANTES</small></article>
				<article><span>03</span><h3>Agencias y freelancers</h3><p>Organizá referencias y acelerá la producción mensual de cada marca.</p><small>MARCA → ESCALA</small></article>
			</div>
		</section>

		<section class="pricing" id="precios">
			<div class="section-heading centered"><span>PRECIOS SIMPLES</span><h2>Elegí cuánto querés crear.</h2><p>Todos los planes incluyen la biblioteca y el flujo guiado.</p></div>
			<div class="plans-grid">
				{plans.map((plan) => <article class:list={{ featured: plan.featured }}>
					{plan.featured && <span class="popular">MÁS ELEGIDO</span>}<h3>{plan.name}</h3><p>{plan.note}</p><div class="price"><small>USD</small><b>{plan.price}</b><span>/mes</span></div><strong>{plan.credits}</strong><a href={plan.href}>{plan.cta} <b>→</b></a><ul>{plan.features.map((feature) => <li><i>✓</i>{feature}</li>)}</ul>
				</article>)}
			</div>
		</section>

		<section class="faq">
			<div class="section-heading centered"><span>PREGUNTAS FRECUENTES</span><h2>Todo lo que necesitás saber.</h2></div>
			<div class="faq-list">{faqs.map((faq) => <details><summary><span>{faq.q}</span><i>+</i></summary><p>{faq.a}</p></details>)}</div>
		</section>

		<section class="final-cta">
			<div class="final-glow"></div><div class="final-grid"></div>
			<div class="final-copy"><span>EMPEZÁ HOY</span><h2>¿Listo para crear imágenes que den ganas de comprar?</h2><p>Conectá tu marca y generá tus primeras tres imágenes gratis.</p><a href="/app/">Crear mi cuenta gratis <b>→</b></a></div>
			<img src="/images/creattia/moki-mascot.webp" alt="Moki, la mascota de Creattia" width="1254" height="1254" loading="lazy" />
		</section>
	</main>

	<footer><a href="#inicio" class="footer-brand"><img src="/images/creattia/moki-mascot.webp" alt="" width="1254" height="1254" loading="lazy"/><strong>Creattia</strong></a><p>Imágenes publicitarias con IA para negocios que venden.</p><nav><a href="/legal/terminos/">Términos</a><a href="/legal/privacidad/">Privacidad</a><a href="/app/">Ingresar</a></nav></footer>

	<script>
		const tabs = [...document.querySelectorAll<HTMLButtonElement>('[data-tool-tab]')];
		const panels = [...document.querySelectorAll<HTMLElement>('[data-tool-panel]')];
		tabs.forEach((tab) => tab.addEventListener('click', () => {
			const target = tab.dataset.toolTab;
			tabs.forEach((button) => { const active = button === tab; button.classList.toggle('active', active); button.setAttribute('aria-selected', String(active)); });
			panels.forEach((panel) => { panel.hidden = panel.dataset.toolPanel !== target; });
		}));
	</script>
</Layout>

<style>
	:global(html) { scroll-behavior: smooth; background: #f8f8f6; }
	:global(body) { overflow-x: hidden; background: #f8f8f6; color: #151417; font-family: 'Manrope Variable', Manrope, sans-serif; }
	:global(a), :global(button) { -webkit-tap-highlight-color: transparent; }
	.site-header { position: fixed; z-index: 50; width: min(760px, calc(100% - 28px)); min-height: 66px; left: 50%; top: 22px; padding: 7px 8px 7px 14px; display: flex; align-items: center; gap: 18px; border: 1px solid rgba(18,17,20,.09); border-radius: 999px; background: rgba(255,255,255,.82); box-shadow: 0 18px 50px rgba(31,25,36,.08); backdrop-filter: blur(22px); transform: translateX(-50%); }
	.brand { display: flex; align-items: center; gap: 7px; color: #151417; text-decoration: none; }
	.brand img { width: 39px; height: 39px; object-fit: contain; }
	.brand strong { font-size: 15px; letter-spacing: -.04em; }
