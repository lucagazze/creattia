<script>
	// Lógica interactiva para cambiar de pestañas en "All-in-One"
	const tabButtons = document.querySelectorAll('[data-tab-target]');
	const tabPanels = document.querySelectorAll('[data-tab-panel]');

	tabButtons.forEach(button => {
		button.addEventListener('click', () => {
			const targetId = button.getAttribute('data-tab-target');

			// Actualizar botones
			tabButtons.forEach(btn => {
				btn.setAttribute('aria-selected', btn === button ? 'true' : 'false');
			});

			// Actualizar paneles
			tabPanels.forEach(panel => {
				if (panel.id === targetId) {
					panel.removeAttribute('hidden');
				} else {
					panel.setAttribute('hidden', '');
				}
			});
		});
	});

	// Menú móvil
	const mobileToggle = document.getElementById('mobile-toggle');
	const mobileOverlay = document.getElementById('mobile-overlay');

	if (mobileToggle && mobileOverlay) {
		mobileToggle.addEventListener('click', () => {
			mobileToggle.classList.toggle('active');
			mobileOverlay.classList.toggle('active');
			document.body.classList.toggle('menu-open');
		});

		// Cerrar menú al hacer clic en enlaces del menú
		const mobileLinks = mobileOverlay.querySelectorAll('.mobile-nav-link');
		mobileLinks.forEach(link => {
			link.addEventListener('click', () => {
				mobileToggle.classList.remove('active');
				mobileOverlay.classList.remove('active');
				document.body.classList.remove('menu-open');
			});
		});
	}

	// Efecto 3D Scroll Perspective en el Video Walkthrough
	const walkthroughVideo = document.querySelector('.walkthrough-video-container') as HTMLElement | null;
	if (walkthroughVideo) {
		const updatePerspective = () => {
			const rect = walkthroughVideo.getBoundingClientRect();
			const windowHeight = window.innerHeight;
			const progress = Math.min(Math.max((windowHeight - rect.top) / (0.8 * windowHeight), 0), 1);
			const inverse = 1 - progress;
			const scale = 1 + 0.12 * inverse;
			const rotateX = 15 * inverse;
			
			walkthroughVideo.style.transform = `perspective(1000px) rotateX(${rotateX}deg) scale(${scale})`;
			walkthroughVideo.style.opacity = String(0.4 + 0.6 * progress);
			walkthroughVideo.style.transition = 'transform 0.1s ease-out, opacity 0.1s ease-out';
		};
		window.addEventListener('scroll', updatePerspective);
		window.addEventListener('resize', updatePerspective);
		updatePerspective();
	}

	// Lógica de Scroll de Showcase Carousel (Auto-scroll + Manual + Drag)
	const track = document.querySelector('.showcase-marquee') as HTMLElement | null;
	const prevBtn = document.querySelector('.prev-btn');
	const nextBtn = document.querySelector('.next-btn');
	if (track && prevBtn && nextBtn) {
		const cardWidth = 300; // 280px card + 20px gap
		
		const scrollNext = () => {
			const maxScrollLeft = track.scrollWidth - track.clientWidth;
			if (track.scrollLeft >= maxScrollLeft - 10) {
				track.scrollTo({ left: 0, behavior: 'smooth' });
			} else {
				track.scrollBy({ left: cardWidth, behavior: 'smooth' });
			}
		};
		
		const scrollPrev = () => {
			if (track.scrollLeft <= 10) {
				track.scrollTo({ left: track.scrollWidth, behavior: 'smooth' });
			} else {
				track.scrollBy({ left: -cardWidth, behavior: 'smooth' });
			}
		};
		
		prevBtn.addEventListener('click', () => {
			scrollPrev();
			resetAutoScroll();
		});
		nextBtn.addEventListener('click', () => {
			scrollNext();
			resetAutoScroll();
		});
		
		// Auto-scroll cada 3 segundos
		let autoScrollInterval = setInterval(scrollNext, 3000);
		
		const resetAutoScroll = () => {
			clearInterval(autoScrollInterval);
			autoScrollInterval = setInterval(scrollNext, 3000);
		};

		// DRAG-TO-SCROLL (Grab to slide)
		let isDown = false;
		let startX: number;
		let scrollLeft: number;

		track.addEventListener('mousedown', (e: MouseEvent) => {
			isDown = true;
			track.style.scrollBehavior = 'auto'; // Disable smooth-scroll animation during dragging
			track.style.cursor = 'grabbing';
			track.style.userSelect = 'none';
			startX = e.pageX - track.offsetLeft;
			scrollLeft = track.scrollLeft;
			clearInterval(autoScrollInterval); // Pause auto-scroll while dragging
		});

		track.addEventListener('mouseleave', () => {
			if (isDown) {
				isDown = false;
				track.style.scrollBehavior = 'smooth';
				track.style.cursor = 'grab';
				track.style.userSelect = '';
				resetAutoScroll(); // Resume auto-scroll
			}
		});

		track.addEventListener('mouseup', () => {
			if (isDown) {
				isDown = false;
				track.style.scrollBehavior = 'smooth';
				track.style.cursor = 'grab';
				track.style.userSelect = '';
				resetAutoScroll(); // Resume auto-scroll
			}
		});

		track.addEventListener('mousemove', (e: MouseEvent) => {
			if (!isDown) return;
			e.preventDefault();
			const x = e.pageX - track.offsetLeft;
			const walk = (x - startX) * 1.5; // multiplier for speed
			track.scrollLeft = scrollLeft - walk;
		});

		// Touch events
		track.addEventListener('touchstart', (e: TouchEvent) => {
			isDown = true;
			track.style.scrollBehavior = 'auto'; // Disable smooth-scroll during touch drag
			startX = e.touches[0].pageX - track.offsetLeft;
			scrollLeft = track.scrollLeft;
			clearInterval(autoScrollInterval);
		}, { passive: true });

		track.addEventListener('touchend', () => {
			if (isDown) {
				isDown = false;
				track.style.scrollBehavior = 'smooth';
				resetAutoScroll();
			}
		});

		track.addEventListener('touchmove', (e: TouchEvent) => {
			if (!isDown) return;
			const x = e.touches[0].pageX - track.offsetLeft;
			const walk = (x - startX) * 1.5;
			track.scrollLeft = scrollLeft - walk;
		}, { passive: true });
	}

	// Lógica de Rotación 3D del Cylinder Carousel (All-in-One)
	const cylinder = document.querySelector('.carousel-cylinder') as HTMLElement | null;
	if (cylinder) {
		let angle = 0;
		let lastTime = performance.now();
		
		const animate = (time: number) => {
			const delta = time - lastTime;
			lastTime = time;
			
			// Rotar la base por una cantidad fija por milisegundo (-0.006 grados/ms)
			angle = (angle - 0.006 * delta) % 360;
			cylinder.style.transform = `rotateY(${angle}deg)`;
			
			requestAnimationFrame(animate);
		};
		
		requestAnimationFrame(animate);
	}
</script>

