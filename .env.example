# Supabase — variables públicas del navegador
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Supabase — solo servidor, nunca exponer en el cliente
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# OpenAI — solo servidor
OPENAI_API_KEY=sk-proj-...
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_ANALYSIS_MODEL=gpt-5.4-mini

# Mercado Pago — solo servidor
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-...
MERCADO_PAGO_PLAN_CREATOR_ID=your_creator_preapproval_plan_id
MERCADO_PAGO_PLAN_PRO_ID=your_pro_preapproval_plan_id
MERCADO_PAGO_PLAN_SCALE_ID=your_scale_preapproval_plan_id
MERCADO_PAGO_PLAN_ID=your_creator_preapproval_plan_id
MERCADO_PAGO_WEBHOOK_SECRET=your_webhook_secret

# URL pública, sin barra final
PUBLIC_SITE_URL=https://creattia.app
