{
  "functions": {
    "api/draft-reply.ts": { "maxDuration": 60 },
    "api/chat.ts": { "maxDuration": 60 },
    "api/scrape-all.ts": { "maxDuration": 60 }
  },
  "rewrites": [
    {
      "source": "/api/klaviyo/:path*",
      "destination": "/api/klaviyo/[...path]"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/update-cerebro",
      "schedule": "0 9 * * *"
    }
  ]
}

