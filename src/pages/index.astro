---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import localManifest from '../../docs/reference-library.starter-50.json';

type StoredReference = { templateId: number; imagePath: string };

const supabaseUrl = String(import.meta.env.PUBLIC_SUPABASE_URL || '').replace(/\/$/, '');
const localById = new Map(localManifest.items.map((item) => [item.templateId, item.localImage.replace(/^public/, '')]));
const storedById = new Map<number, string>();

if (supabaseUrl) {
	try {
		const manifestResponse = await fetch(`${supabaseUrl}/storage/v1/object/public/creative-references/manifests/starter-static-50.json`);
		if (manifestResponse.ok) {
			const manifest = await manifestResponse.json() as { items?: StoredReference[] } | StoredReference[];
			const items = Array.isArray(manifest) ? manifest : (manifest.items || []);
			for (const item of items) storedById.set(item.templateId, `${supabaseUrl}/storage/v1/object/public/creative-references/${item.imagePath}`);
		}
	} catch {
		// The bundled originals keep the landing available if Storage is temporarily unreachable.
	}
}

const reference = (id: number) => storedById.get(id) || localById.get(id) || '';

const showcase = [
	{ id: 18, label: 'Envío gratis' }, { id: 2, label: 'Reseñas' }, { id: 40, label: 'Producto' },
	{ id: 23, label: 'Comparativas' }, { id: 30, label: 'Listas' }, { id: 17, label: '3x2' },
	{ id: 42, label: 'Lifestyle' }, { id: 6, label: 'Antes y después' },
];

const steps = [
	{ number: '01', title: 'Pegá tu URL', copy: 'Creattia aprende tu identidad, tus productos y la información importante de tu negocio.', kind: 'url' },
	{ number: '02', title: 'Explorá ideas', copy: 'Recorré categorías de venta y guardá las estructuras que mejor encajan con tu objetivo.', kind: 'ideas' },
	{ number: '03', title: 'Elegí tus productos', copy: 'Usá uno, combiná varios o creá una pieza general de toda tu marca.', kind: 'products' },
	{ number: '04', title: 'Generá y publicá', copy: 'Recibí de una a cuatro imágenes, descargalas o pedí una nueva variante.', kind: 'result' },
];

const toolTabs = [
	{ id: 'ads', label: 'Anuncios', eyebrow: 'CAMPAÑAS DE VENTA', title: 'Estáticos pensados para detener el scroll.', copy: 'Ofertas, beneficios y argumentos comerciales listos para adaptar a tu producto.', ids: [18, 22, 13, 14, 16] },
	{ id: 'product', label: 'Producto', eyebrow: 'TU PRODUCTO PRIMERO', title: 'Mostrá qué vendés con absoluta claridad.', copy: 'Heroes limpios, escenas de uso, despieces y comparativas que explican el valor.', ids: [40, 42, 43, 46, 44] },
	{ id: 'education', label: 'Contenido', eyebrow: 'EDUCAR PARA CONVERTIR', title: 'Convertí información en contenido fácil de guardar.', copy: 'Listas, preguntas, datos, diagramas y tutoriales con la identidad de tu negocio.', ids: [30, 32, 33, 31, 45] },
	{ id: 'trust', label: 'Confianza', eyebrow: 'PRUEBA SOCIAL', title: 'Dale a cada compra una razón para sentirse segura.', copy: 'Reseñas, testimonios, autoridad y garantías presentadas con una jerarquía clara.', ids: [2, 3, 7, 11, 48] },
];

const businesses = ['E-commerce', 'Moda', 'Belleza', 'Gastronomía', 'Fitness', 'Servicios', 'Productos digitales', 'Apps y SaaS'];
const ideaTags = ['Envío gratis', '3x2', 'Cuotas', 'Reseñas', 'Comparativas', 'Antes y después', 'Bundles', 'Listas', 'Mitos', 'Lifestyle', 'Garantías', 'Lanzamientos', 'Preguntas', 'Despieces'];

const comparison = [
	{ feature: 'Ideas de venta organizadas', creattia: true, chat: false, canva: false, image: false },
	{ feature: 'Identidad de marca aplicada', creattia: true, chat: 'Parcial', canva: 'Manual', image: 'Parcial' },
	{ feature: 'Productos guardados y reutilizables', creattia: true, chat: false, canva: false, image: false },
	{ feature: 'Sin prompts ni diseño', creattia: true, chat: false, canva: false, image: false },
	{ feature: 'Variantes e historial', creattia: true, chat: 'Parcial', canva: 'Manual', image: 'Parcial' },
];

const plans = [
	{ name: 'Gratis', price: '0', description: 'Probá el flujo completo antes de elegir.', credits: '3 imágenes', href: '/app/?plan=free', features: ['1 marca', 'Biblioteca completa', 'Sin tarjeta'] },
	{ name: 'Pro', price: '39', description: 'Para crear y probar nuevas ideas cada semana.', credits: '120 imágenes/mes', href: '/app/?plan=pro', features: ['1 marca conectada', 'Hasta 5 productos por pieza', 'Historial, favoritos y variantes'], featured: true },
	{ name: 'Escala', price: '79', description: 'Para negocios con más volumen creativo.', credits: '300 imágenes/mes', href: '/app/?plan=scale', features: ['Todo lo de Pro', 'Mayor volumen mensual', 'Flujo de trabajo prioritario'] },
];

const faqs = [
	{ q: '¿Qué crea Creattia?', a: 'Imágenes publicitarias estáticas para anuncios, redes sociales y tiendas online usando tu marca y tus productos.' },
	{ q: '¿Necesito saber diseñar o escribir prompts?', a: 'No. Elegís una idea, el producto, el formato y cuántas variantes querés. Creattia organiza el resto.' },
	{ q: '¿Puedo usar más de un producto?', a: 'Sí. Podés elegir uno, combinar varios o crear una comunicación general sin seleccionar un producto.' },
	{ q: '¿Puedo modificar una imagen generada?', a: 'Sí. Podés reutilizarla como referencia, pedir un cambio y decidir si querés conservarla, variarla un poco o explorar otra versión.' },
	{ q: '¿De dónde salen las ideas?', a: 'La biblioteca reúne estructuras visuales organizadas por objetivo: ofertas, prueba social, educación, comparativas, producto y autoridad.' },
	{ q: '¿La prueba gratis necesita tarjeta?', a: 'No. Creás tu cuenta y recibís tres imágenes para probar el flujo completo.' },
];
---

<Layout
	title="Creattia | La plataforma para crear imágenes que venden"
	description="Convertí tu web y tus productos en imágenes publicitarias listas para vender. Sin diseñar ni escribir prompts."
	ogTitle="Creattia | Imágenes publicitarias para tu negocio"
	ogDescription="Elegí una idea, sumá tu producto y generá imágenes listas para publicar."
	ogImage="/images/creattia/moki-og.jpg"
>
	<header class="floating-header" aria-label="Navegación principal">
		<a class="logo-bubble" href="#inicio" aria-label="Creattia, volver al inicio"><img src="/images/creattia/moki-mascot.webp" alt="" width="1254" height="1254" /></a>
		<nav>
			<a href="#como-funciona">Cómo funciona</a>
			<a href="#biblioteca">Biblioteca</a>
			<a href="#precios">Precios</a>
			<a href="/app/">Ingresar</a>
		</nav>
		<a class="outline-cta" href="/app/">Empezar gratis <span>→</span></a>
	</header>

	<main>
		<section class="hero" id="inicio">
			<div class="hero-copy">
				<span class="gradient-pill">IMÁGENES CON IA PARA TU NEGOCIO</span>
				<h1>La plataforma N°1 para generar imágenes que venden.</h1>
				<p>Convertí tu web y tus productos en anuncios listos para publicar. Sin diseñar, sin escribir prompts y sin empezar de cero.</p>
				<a class="gradient-cta" href="/app/">Crear 3 imágenes gratis <b>→</b></a>
				<div class="hero-proof">
					<span><i>✦</i><b>50 estructuras</b><small>listas para explorar</small></span>
					<span><i>✦</i><b>1–4 imágenes</b><small>por cada creación</small></span>
				</div>
			</div>
			<div class="hero-video">
				<video autoplay muted loop playsinline preload="metadata" aria-label="Demostración de Creattia">
					<source src="/videos/creattia-hero-4x3.mp4" type="video/mp4" />
				</video>
			</div>
		</section>

		<section class="showcase" id="biblioteca">
			<div class="two-line-heading"><h2>Probablemente ya viste anuncios así.</h2><h2>Ahora pueden llevar tu producto.</h2></div>
			<div class="image-marquee" aria-label="Ejemplos de la biblioteca de Creattia">
				<div class="image-track">
					{[...showcase, ...showcase].map((item, index) => (
						<a class:list={{ 'reference-card': true, lifted: index % 3 === 1 }} href="/app/">
							<img src={reference(item.id)} alt={`Ejemplo de ${item.label}`} width="1080" height="1350" loading={index < showcase.length ? 'eager' : 'lazy'} />
							<span>{item.label}<b>↗</b></span>
						</a>
					))}
				</div>
			</div>
			<a class="simple-link" href="/app/">Ver todas las ideas <span>→</span></a>
		</section>

		<section class="manifesto">
			<div>
				<p>En Creattia estamos cambiando cómo los negocios <em>crean imágenes.</em></p>
				<p>La plataforma entiende tu marca, tus productos y el objetivo de cada pieza.</p>
				<p>Así producís como un equipo creativo completo, <em>sin contratar uno.</em></p>
			</div>
			<img src="/images/creattia/moki-mascot.webp" alt="Moki, la mascota de Creattia" width="1254" height="1254" loading="lazy" />
		</section>

		<section class="how-it-works" id="como-funciona">
			<div class="center-heading"><span>CÓMO FUNCIONA</span><h2>De tu web a una imagen lista para vender.</h2></div>
			<div class="step-list">
				{steps.map((step) => (
					<article class="step-row">
						<div class="step-number"><b>{step.number}</b></div>
						<div class="step-copy"><h3>{step.title}</h3><p>{step.copy}</p></div>
						<div class:list={{ 'step-demo': true, [step.kind]: true }}>
							{step.kind === 'url' && <div class="browser-demo"><span class="browser-dots"><i></i><i></i><i></i></span><div class="url-field"><b>⌕</b><span>tumarca.com</span><i>→</i></div><small>Analizando identidad y catálogo…</small></div>}
							{step.kind === 'ideas' && <div class="idea-stack">{[18, 23, 30].map((id) => <img src={reference(id)} alt="" width="1080" height="1350" loading="lazy" />)}</div>}
							{step.kind === 'products' && <div class="product-picker"><span>Elegí qué querés mostrar</span><div>{[40, 42, 46].map((id, index) => <button type="button" aria-label={`Producto ${index + 1}`}><img src={reference(id)} alt="" width="1080" height="1350" loading="lazy" /><i>{index < 2 ? '✓' : '+'}</i></button>)}</div><small>2 productos seleccionados</small></div>}
							{step.kind === 'result' && <div class="result-demo"><img src={reference(18)} alt="" width="1080" height="1350" loading="lazy" /><div><button type="button">Descargar</button><button type="button">Nueva variante</button></div></div>}
						</div>
					</article>
				))}
			</div>
		</section>

		<section class="all-in-one">
			<div class="center-heading wide"><span>TODO EN UN SOLO LUGAR</span><h2>Una plataforma para todas tus imágenes.</h2><p><em>Dejá de saltar entre herramientas, plantillas y pestañas.</em> Creattia reúne el proceso completo para pasar de una idea a una pieza lista.</p></div>
			<div class="tool-panels">
				{toolTabs.map((tab, tabIndex) => (
					<article data-tool-panel={tab.id} hidden={tabIndex !== 0}>
						<div class="tool-images">{tab.ids.map((id, imageIndex) => <img src={reference(id)} alt={`Ejemplo ${imageIndex + 1} de ${tab.label}`} width="1080" height="1350" loading={tabIndex === 0 ? 'eager' : 'lazy'} />)}</div>
						<div class="tool-description"><span>{tab.eyebrow}</span><h3>{tab.title}</h3><p>{tab.copy}</p><a href="/app/">Crear una imagen <b>→</b></a></div>
					</article>
				))}
			</div>
			<div class="tool-tabs" role="tablist" aria-label="Tipos de imágenes">
				{toolTabs.map((tab, index) => <button type="button" role="tab" data-tool-tab={tab.id} aria-selected={index === 0 ? 'true' : 'false'}>{tab.label}</button>)}
			</div>
		</section>

		<section class="brand-dna">
			<div class="center-heading"><span>IMPULSADA POR</span><h2>El ADN de tu marca.</h2><p>Creattia aprende lo que hace reconocible a tu negocio y lo reutiliza cada vez que creás.</p></div>
			<div class="dna-grid">
				<article class="dna-style"><h3>Captura tu estilo</h3><p>Colores, tono, composición y forma de presentar tus productos.</p><div class="color-dots"><i></i><i></i><i></i><i></i><i></i></div></article>
				<article class="dna-triggers"><h3>Entiende qué hace comprar</h3><p>Beneficios, objeciones, urgencia y argumentos comerciales de tu negocio.</p><div class="trigger-meter"><i></i><i></i><i></i><i></i></div></article>
				<div class="dna-mascot"><div></div><img src="/images/creattia/moki-mascot.webp" alt="Moki representa el ADN de marca dentro de Creattia" width="1254" height="1254" loading="lazy" /></div>
				<article class="dna-audience"><h3>Conoce a tu audiencia</h3><p>Adapta la jerarquía visual al objetivo y al tipo de comunicación.</p><div class="channel-dots"><i>f</i><i>◎</i><i>▶</i><i>✉</i></div></article>
				<article class="dna-private"><h3>Mantiene tus datos privados</h3><p>Tu identidad, productos y generaciones permanecen dentro de tu espacio.</p><span>▣ &nbsp; Tu espacio privado</span></article>
			</div>
		</section>

		<section class="business-types">
			<div class="center-heading"><span>HECHA PARA NEGOCIOS REALES</span><h2>Funciona para cualquier tipo de negocio.</h2></div>
			<div class="business-marquee"><div class="business-track">{[...businesses, ...businesses].map((business, index) => <span><i>{String((index % businesses.length) + 1).padStart(2, '0')}</i><b>{business}</b><em>↗</em></span>)}</div></div>
		</section>

		<section class="content-calendar">
			<div class="calendar-copy"><span>IDEAS SIEMPRE DISPONIBLES</span><h2>Llená tu calendario de anuncios con meses de anticipación.</h2><p>Guardá lo que te gusta, descartá lo que no encaja y volvé a usar una estructura cuando la necesites.</p><div class="moki-tip"><img src="/images/creattia/moki-mascot.webp" alt="" width="1254" height="1254" loading="lazy" /><span>Como deslizar ideas, pero para vender.</span></div></div>
			<div class="phone-stage">
				<div class="phone"><div class="phone-top"></div><div class="phone-screen"><span>Creattia <small>12 de 50</small></span><img src={reference(23)} alt="Ejemplo de comparativa dentro de Creattia" width="1080" height="1350" loading="lazy" /><div><button type="button">×</button><button type="button">♥</button></div></div></div>
			</div>
			<div class="idea-library"><h3>50 estructuras listas para explorar</h3><div>{[...ideaTags, ...ideaTags].map((tag) => <span>{tag}</span>)}</div></div>
		</section>

		<section class="intelligence">
			<div class="center-heading wide"><span>BIBLIOTECA CREATTIA</span><h2>Ideas organizadas para que nunca empieces desde una pantalla vacía.</h2><p>Cada estructura tiene un objetivo claro y te ayuda a decidir qué crear antes de generar.</p></div>
			<div class="category-nodes" aria-label="Familias de ideas"><span>OF</span><span>PS</span><span>PR</span><span>ED</span><span>VS</span><span>AU</span></div>
			<div class="engine-stage">
				<div class="engine-device"><span>Tu próxima idea</span><img src={reference(33)} alt="Ejemplo educativo de Creattia" width="1080" height="1350" loading="lazy" /><b>Lista para adaptar</b></div>
				<div class="insight-card insight-one"><i>✦</i><span><b>Jerarquía clara</b><small>El mensaje principal se entiende primero.</small></span></div>
				<div class="insight-card insight-two"><i>✓</i><span><b>Ángulo organizado</b><small>Producto, oferta y objetivo alineados.</small></span></div>
				<div class="insight-card insight-three"><i>↗</i><span><b>Fácil de iterar</b><small>Generá otra versión sin volver a empezar.</small></span></div>
			</div>
			<div class="truthful-stats"><div><b>50</b><span>estructuras iniciales</span></div><div><b>6</b><span>familias principales</span></div><div><b>1–4</b><span>imágenes por creación</span></div><div><b>3</b><span>formatos principales</span></div></div>
		</section>

		<section class="channels">
			<div class="center-heading"><span>LISTA PARA PUBLICAR</span><h2>Usá tus imágenes donde ya vendés.</h2><p>Elegí el formato correcto y llevá la misma identidad a todos tus canales.</p></div>
			<div class="channel-grid"><article><i class="meta">∞</i><h3>Meta Ads</h3><p>Campañas y remarketing.</p></article><article><i class="instagram">◎</i><h3>Instagram</h3><p>Feed e historias.</p></article><article><i class="facebook">f</i><h3>Facebook</h3><p>Anuncios y publicaciones.</p></article><article><i class="store">↗</i><h3>Tu tienda</h3><p>Banners y promociones.</p></article></div>
		</section>

		<section class="comparison">
			<div class="center-heading"><span>UNA SOLA PLATAFORMA</span><h2>Todo lo necesario para crear estáticos.</h2><p>Menos herramientas abiertas. Más claridad para decidir y publicar.</p></div>
			<div class="compare-table" role="table" aria-label="Comparación de herramientas">
				<div class="compare-row compare-head" role="row"><span></span><b><img src="/images/creattia/moki-mascot.webp" alt="Creattia" width="1254" height="1254" /></b><b>Chat general</b><b>Editor manual</b><b>Generador de imagen</b></div>
				{comparison.map((row) => <div class="compare-row" role="row"><strong>{row.feature}</strong>{[row.creattia,row.chat,row.canva,row.image].map((value,index) => <span class:list={{ yes: value === true, creattia: index === 0 }}>{value === true ? '✓' : value === false ? '×' : value}</span>)}</div>)}
			</div>
		</section>

		<section class="privacy">
			<div class="privacy-heading"><span>PRIVACIDAD DESDE EL DISEÑO</span><h2>Una gran marca merece una gran <em>privacidad.</em></h2></div>
			<div class="privacy-intro"><p>Tu identidad y tus productos son activos del negocio. Creattia los mantiene organizados dentro de tu cuenta.</p><p>Vos decidís qué conectar, qué guardar, qué eliminar y qué volver a utilizar en cada creación.</p></div>
			<div class="privacy-panel"><div class="privacy-points"><article><i>01</i><span><b>Datos separados</b><small>Cada cuenta trabaja con su propia biblioteca.</small></span></article><article><i>02</i><span><b>Productos bajo control</b><small>Elegís qué información usar en cada pieza.</small></span></article><article><i>03</i><span><b>Historial reutilizable</b><small>Volvé a tus resultados sin perder contexto.</small></span></article></div><div class="privacy-mascot"><img src="/images/creattia/moki-mascot.webp" alt="Moki protege tu espacio de trabajo" width="1254" height="1254" loading="lazy" /><span>▣ &nbsp; Tu espacio. Tus imágenes.</span></div></div>
		</section>

		<section class="for-people">
			<div class="center-heading"><span>PARA QUIEN ESTÁ HACIENDO EL TRABAJO</span><h2>Creada para vender más. No para aprender otra herramienta.</h2></div>
			<div class="people-grid"><article><span>01</span><h3>Dueños de e-commerce</h3><p>Pasá de una promoción a una imagen sin depender de un diseñador para cada prueba.</p><small>PRODUCTO → CAMPAÑA</small></article><article><span>02</span><h3>Equipos de marketing</h3><p>Probá más ángulos y mantené una identidad coherente en cada nueva pieza.</p><small>IDEA → VARIANTES</small></article><article><span>03</span><h3>Agencias y freelancers</h3><p>Organizá referencias y acelerá la producción mensual de cada marca.</p><small>MARCA → ESCALA</small></article></div>
		</section>

		<section class="pricing" id="precios">
			<div class="center-heading"><span>PRECIOS SIMPLES</span><h2>Elegí cuánto querés crear.</h2><p>Tres planes claros. La misma biblioteca y el mismo flujo guiado.</p></div>
			<div class="plans">{plans.map((plan) => <article class:list={{ featured: plan.featured }}><span>{plan.featured ? 'MÁS ELEGIDO' : 'CREATTIA'}</span><h3>{plan.name}</h3><p>{plan.description}</p><div class="price"><small>USD</small><b>${plan.price}</b><em>/mes</em></div><strong>{plan.credits}</strong><a href={plan.href}>Elegir {plan.name} <b>→</b></a><ul>{plan.features.map((feature) => <li><i>✓</i>{feature}</li>)}</ul></article>)}</div>
		</section>

		<section class="faq">
			<div class="center-heading"><span>PREGUNTAS FRECUENTES</span><h2>Todo lo que necesitás saber.</h2></div>
			<div class="faq-list">{faqs.map((item, index) => <details open={index === 0}><summary>{item.q}<i>+</i></summary><p>{item.a}</p></details>)}</div>
		</section>

		<section class="final-cta">
			<div><span>LISTO PARA CREAR</span><h2>Tu próxima imagen puede empezar ahora.</h2><p>Conectá tu negocio, elegí una idea y probá el flujo completo.</p><a href="/app/">Crear 3 imágenes gratis <b>→</b></a></div>
			<img src="/images/creattia/moki-mascot.webp" alt="Moki te invita a probar Creattia" width="1254" height="1254" loading="lazy" />
		</section>
	</main>

	<footer><a href="#inicio"><img src="/images/creattia/moki-mascot.webp" alt="" width="1254" height="1254" /><strong>Creattia</strong></a><p>Imágenes publicitarias para negocios que quieren crear más.</p><nav><a href="/legal/privacidad/">Privacidad</a><a href="/legal/terminos/">Términos</a><a href="/app/">Ingresar</a></nav></footer>
</Layout>

<script>
	const tabs = [...document.querySelectorAll<HTMLButtonElement>('[data-tool-tab]')];
	const panels = [...document.querySelectorAll<HTMLElement>('[data-tool-panel]')];
	for (const tab of tabs) tab.addEventListener('click', () => {
		const selected = tab.dataset.toolTab;
		for (const button of tabs) button.setAttribute('aria-selected', String(button === tab));
		for (const panel of panels) panel.hidden = panel.dataset.toolPanel !== selected;
	});
</script>

<style>
	:global(html){scroll-behavior:smooth;background:#fff}
	:global(body){overflow-x:hidden;background:#fff;color:#1d1d1f;font-family:'Inter Variable',Inter,system-ui,sans-serif}
	:global(a),:global(button){-webkit-tap-highlight-color:transparent}
	.floating-header{width:min(680px,calc(100% - 28px));height:58px;position:fixed;z-index:50;left:50%;top:28px;display:flex;gap:8px;transform:translateX(-50%)}
	.logo-bubble{width:58px;height:58px;flex:0 0 58px;display:grid;place-items:center;border:1px solid #e5e5e6;border-radius:50%;background:rgba(255,255,255,.94);box-shadow:0 16px 38px rgba(24,24,28,.07);backdrop-filter:blur(18px)}
