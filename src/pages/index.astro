	{ name: 'Gratis', price: '0', description: 'Probá el flujo completo antes de elegir.', credits: '3 imágenes', href: '/app/?plan=free', features: ['1 marca conectada', 'Biblioteca completa', 'Sin tarjeta de crédito'] },
