{
  "rewrites": [
    {
      "source": "/api/google-signin",
      "destination": "/api/complete-contact"
    },
    {
      "source": "/api/preview",
      "destination": "/api/oauth"
    },
    {
      "source": "/api/shopify-callback",
      "destination": "/api/oauth"
    },
    {
      "source": "/api/klaviyo/:path*",
      "destination": "/api/klaviyo/[...path]"
    },
    {
      "source": "/api/shopify/:path*",
      "destination": "/api/shopify/[...path]"
    },
    {
      "source": "/((?!api/|meta-callback\\.html).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/update-cerebro",
      "schedule": "0 9 * * *"
    }
  ]
}

