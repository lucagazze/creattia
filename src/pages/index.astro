];


const testimonials = [
	{ name: 'Anna Clark', country: 'CA', date: '6 Mar 2026', text: 'Llevo todo sola y Creattia básicamente me salvó la vida jaja. Publicaciones, anuncios, todo listo sin tener que estar encima. 10/10.' },
