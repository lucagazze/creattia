---
export const prerender = true;
import Layout from '../layouts/Layout.astro';

const currentYear = new Date().getFullYear();

const plans = [
	{ code: 'creator', name: 'Creator', price: 19, credits: 40, copy: 'Para crear contenido todas las semanas.', featured: false },
	{ code: 'pro', name: 'Pro', price: 39, credits: 120, copy: 'Para probar más ideas y anuncios.', featured: true },
	{ code: 'scale', name: 'Scale', price: 79, credits: 300, copy: 'Para equipos que producen a diario.', featured: false },
];

const categories = [
	{ title: 'Vender más', copy: 'Promos y ofertas para impulsar la compra.', color: '#ff7a59', branches: ['Promociones', 'Packs', 'Envío gratis', 'Cuotas'] },
	{ title: 'Generar confianza', copy: 'Reseñas y pruebas que reducen dudas.', color: '#9b7cf3', branches: ['Reseñas', 'Mensajes', 'UGC', 'Resultados'] },
	{ title: 'Convencer', copy: 'Comparaciones que facilitan la decisión.', color: '#ef646f', branches: ['Competencia', 'Valor y costo', 'Antes y después'] },
	{ title: 'Educar', copy: 'Contenido que explica por qué elegirte.', color: '#55a8ff', branches: ['Datos', 'Mitos', 'Preguntas', 'Storytelling'] },
	{ title: 'Mostrar producto', copy: 'Tu producto claro, atractivo y en contexto.', color: '#3fc68c', branches: ['Hero', 'Lifestyle', 'Detalle', 'Uso'] },
	{ title: 'Construir autoridad', copy: 'Credenciales e historias que dan respaldo.', color: '#e7b348', branches: ['Expertos', 'Certificaciones', 'Fundador'] },
];

const businessTypes = [
	{ name: 'E-commerce', color: '#a77bf7', icon: 'M3 4h2l2 10h10l2-7H6m3 12a1 1 0 1 0 0 .01M17 19a1 1 0 1 0 0 .01' },
	{ name: 'Gastronomía', color: '#ff9b63', icon: 'M7 3v7m-2-7v4a2 2 0 0 0 4 0V3M7 10v11m8-18c-2 3-2 7 1 9v9m0-9V3' },
	{ name: 'Moda', color: '#f27cb0', icon: 'M12 7a2 2 0 1 0-2-2m2 2v2L3 17h18L12 9' },
	{ name: 'Belleza', color: '#df8cff', icon: 'M12 3c3 4 5 7 5 10a5 5 0 0 1-10 0c0-3 2-6 5-10m6 1v4m-2-2h4' },
	{ name: 'Fitness', color: '#6ed5a1', icon: 'M4 9v6m3-8v10m10-10v10m3-8v6M7 12h10M2 11v2m20-2v2' },
	{ name: 'Servicios', color: '#75b7ff', icon: 'M9 6V4h6v2m-11 0h16v13H4zM4 11h16M9 11v2h6v-2' },
	{ name: 'Productos digitales', color: '#ffd16c', icon: 'M4 4h16v16H4zM4 8h16m-8 4 4 2.5-4 2.5z' },
	{ name: 'Apps y SaaS', color: '#8f95ff', icon: 'M5 4h5v5H5zm9 0h5v5h-5zM5 14h5v5H5zm9 0h5v5h-5z' },
];

const steps = [
	{ number: '01', icon: '⌕', title: 'Elegí una idea', copy: 'Buscá por objetivo, categoría o tipo de imagen.' },
	{ number: '02', icon: '◇', title: 'Sumá tu producto', copy: 'Elegilo de tu catálogo o subí una foto.' },
	{ number: '03', icon: '▣', title: 'Definí el formato', copy: 'Feed, historia o el tamaño que necesites.' },
	{ number: '04', icon: '✦', title: 'Generá y ajustá', copy: 'Descargá o creá otra versión en segundos.' },
];

const faqs = [
	{ q: '¿Es un pack de imágenes?', a: 'No. Es una aplicación con una biblioteca de ideas que crece y se actualiza dentro de tu cuenta.' },
	{ q: '¿Necesito saber diseñar o usar IA?', a: 'No. Elegís una idea, un producto y un formato. Creattia resuelve el diseño y las instrucciones.' },
	{ q: '¿Cómo usa mi marca y mis productos?', a: 'Conectás tu web e Instagram una vez. Creattia analiza tu identidad e importa tus productos para tenerlos listos al crear.' },
	{ q: '¿Tengo que escribir indicaciones?', a: 'No. Es opcional. Si no agregás nada, la IA usa la información de tu marca, tu producto y la idea que elegiste.' },
	{ q: '¿Cómo funciona la prueba gratuita?', a: 'Creás tu cuenta y recibís 3 generaciones gratis para probar el flujo completo. No necesitás tarjeta.' },
	{ q: '¿Puedo modificar una imagen generada?', a: 'Sí. Podés cambiar el producto, conservar el ángulo o pedir una versión parecida, más libre o completamente nueva.' },
];
---

<Layout
	title="Creattia | Imágenes con IA que venden"
	description="Elegí una idea, sumá tu producto y generá imágenes listas para vender con tu marca. Probá 3 generaciones gratis."
	ogTitle="Creattia | La plataforma N°1 para generar imágenes que venden"
	ogDescription="Generá anuncios y fotos de producto con tu marca, sin diseñar ni escribir prompts. Probá 3 imágenes gratis."
	ogImage="/images/creattia/moki-og.jpg"
	favicon="/images/creattia/moki-favicon-96.png"
	appleTouchIcon="/images/creattia/moki-apple-touch.png"
	manifest="/creattia.webmanifest"
	noindex={true}
>
	<header class="nav-shell">
		<div class="nav-inner">
			<a href="#top" class="brand" aria-label="Creattia, volver al inicio">
				<img src="/images/creattia/moki-favicon-96.png" alt="" width="96" height="96" />
				<b>Creattia</b>
			</a>
			<a href="/app/" class="button button-small">
				<span>Empezar gratis</span>
				<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
			</a>
		</div>
	</header>

	<main id="top">
		<section class="hero">
			<div class="hero-grid" aria-hidden="true"></div>
			<div class="hero-orb hero-orb-one" aria-hidden="true"></div>
			<div class="hero-orb hero-orb-two" aria-hidden="true"></div>
			<div class="hero-inner">
				<div class="hero-copy">
					<span class="eyebrow"><i></i> IMÁGENES CON IA PARA NEGOCIOS</span>
					<h1>La plataforma N°1 para generar <em>imágenes que venden.</em></h1>
					<p>Elegí una idea, sumá tu producto y generá anuncios listos para vender. <strong>Sin diseñar ni escribir prompts.</strong></p>
					<div class="hero-actions">
						<a href="/app/" class="button button-primary">Crear 3 imágenes gratis <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg></a>
						<span><b>✓</b> Google o email · Sin tarjeta</span>
					</div>
				</div>

				<div class="hero-showcase">
					<div class="showcase-video">
						<video autoplay muted loop playsinline preload="auto" poster="/videos/creattia-hero.jpg" aria-label="Creattia transforma una foto de producto en una imagen lista para vender">
							<source src="/videos/creattia-hero.mp4" type="video/mp4" />
						</video>
					</div>
				</div>

				<div class="hero-proof" aria-label="Beneficios principales">
					<span><strong>3 gratis</strong><small>para probar todo</small></span>
					<i></i>
					<span><strong>Tu marca lista</strong><small>sin cargarla de nuevo</small></span>
					<i></i>
					<span><strong>Creá en minutos</strong><small>de producto a anuncio</small></span>
					<i></i>
					<span><strong>Nuevas ideas</strong><small>cada semana</small></span>
				</div>
			</div>
		</section>

		<section class="living-library" id="biblioteca">
			<div class="section-inner split-heading">
				<div>
					<span class="section-kicker">UNA BIBLIOTECA QUE NO PARA DE CRECER</span>
					<h2>Siempre tenés una nueva idea <em>para vender mejor.</em></h2>
				</div>
				<p>Encontrá lo que necesitás por objetivo, elegí una idea y adaptala a tu producto y a tu marca.</p>
			</div>
			<div class="category-grid section-inner">
				{categories.map((category, index) => (
					<article style={'--accent:' + category.color}>
						<header><span>{String(index + 1).padStart(2, '0')}</span><i></i></header>
						<h3>{category.title}</h3>
						<p>{category.copy}</p>
						<div>{category.branches.map((branch) => <span>{branch}<b>›</b></span>)}</div>
					</article>
				))}
			</div>
			<div class="taxonomy-demo section-inner">
				<div class="taxonomy-copy">
					<span class="section-kicker">ENCONTRÁ TODO RÁPIDO</span>
					<h3>La idea exacta.<br />En pocos clics.</h3>
					<p>Buscá, recorré categorías o guardá tus favoritas.</p>
				</div>
				<div class="taxonomy-path">
					<div><small>1 · OBJETIVO</small><strong>Vender más</strong></div><i>→</i>
					<div><small>2 · CATEGORÍA</small><strong>Promociones</strong></div><i>→</i>
					<div><small>3 · TIPO</small><strong>Envío gratis</strong></div><span>✓</span>
				</div>
			</div>
		</section>

		<section class="how" id="como-funciona">
			<div class="section-inner">
				<div class="center-heading light-heading">
					<span class="section-kicker">VOS ELEGÍS. CREATTIA RESUELVE.</span>
					<h2>De una idea a una imagen lista. <em>En minutos.</em></h2>
					<p>Un paso a paso simple, aunque nunca hayas diseñado ni usado inteligencia artificial.</p>
				</div>
				<div class="steps">
					{steps.map((step) => (
						<article>
							<span>{step.number}</span>
							<div class="step-icon">{step.icon}</div>
							<h3>{step.title}</h3>
							<p>{step.copy}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="memory-section">
			<div class="section-inner memory-grid">
				<div class="memory-copy">
					<span class="section-kicker">CONECTÁ TU NEGOCIO UNA VEZ</span>
					<h2>Tu marca y tus productos, <em>siempre listos.</em></h2>
					<p>Creattia analiza tu web e Instagram, importa tus productos y recuerda lo que elegís. La próxima imagen empieza mucho más cerca.</p>
					<ul>
						<li><b>01</b><span><strong>Marca y catálogo</strong><small>Web, Instagram y productos en un solo lugar.</small></span></li>
						<li><b>02</b><span><strong>Favoritos e historial</strong><small>Volvé rápido a tus mejores ideas y creaciones.</small></span></li>
						<li><b>03</b><span><strong>Versiones sin empezar de cero</strong><small>Cambiá el producto o ajustá la imagen anterior.</small></span></li>
					</ul>
				</div>
				<div class="brand-panel" aria-label="Ejemplo de negocio conectado en Creattia">
					<div class="panel-top">
						<div><img src="/images/creattia/moki-favicon-96.png" alt="" width="96" height="96" /><span><strong>Mi negocio</strong><small>Todo listo para crear</small></span></div>
						<b>ACTIVO</b>
					</div>
					<div class="panel-progress"><span></span></div>
					<div class="source-card"><i>↗</i><span><strong>tienda.com</strong><small>Identidad analizada</small></span><b>✓</b></div>
					<div class="source-card"><i>◎</i><span><strong>@mi.negocio</strong><small>Instagram conectado</small></span><b>✓</b></div>
					<div class="source-card"><i>◇</i><span><strong>128 productos</strong><small>Catálogo sincronizado</small></span><b>✓</b></div>
					<div class="panel-ready"><span>✦</span><div><strong>Tu marca está lista</strong><small>Elegí una idea y empezá a crear.</small></div></div>
				</div>
			</div>
		</section>

		<section class="business-section">
			<div class="section-inner business-heading">
				<span class="section-kicker">HECHO PARA NEGOCIOS REALES</span>
				<h2>Si tenés algo para vender, <em>tenés algo para crear.</em></h2>
				<p>Productos, servicios o negocios digitales. Sin experiencia en diseño ni IA.</p>
			</div>
			<div class="business-marquee" aria-label="Tipos de negocio compatibles">
				<div class="business-track">
					<div class="business-set">{businessTypes.map((business) => <span style={'--business-accent:' + business.color}><i><svg viewBox="0 0 24 24" aria-hidden="true"><path d={business.icon} /></svg></i><b>{business.name}</b></span>)}</div>
					<div class="business-set" aria-hidden="true">{businessTypes.map((business) => <span style={'--business-accent:' + business.color}><i><svg viewBox="0 0 24 24" aria-hidden="true"><path d={business.icon} /></svg></i><b>{business.name}</b></span>)}</div>
				</div>
			</div>
		</section>

		<section class="plans-section" id="planes">
			<div class="section-inner">
				<div class="center-heading">
					<span class="section-kicker">3 IMÁGENES GRATIS. SIN TARJETA.</span>
					<h2>Un plan para cada ritmo de creación.</h2>
					<p>Todos incluyen la biblioteca completa, tu marca, productos, historial y nuevas ideas.</p>
				</div>
				<div class="plans-grid">
					{plans.map((plan) => (
						<article class:list={{ featured: plan.featured }}>
							{plan.featured && <span class="popular">MÁS ELEGIDO</span>}
							<small>PLAN {plan.name.toUpperCase()}</small>
							<h3><b>USD</b>{plan.price}<em>/mes</em></h3>
							<p>{plan.copy}</p>
							<strong>{plan.credits} generaciones por mes</strong>
							<ul><li>✓ Biblioteca completa y nuevas ideas</li><li>✓ Marca y catálogo siempre listos</li><li>✓ Historial, favoritos y ajustes</li></ul>
							<a href={'/app/?plan=' + plan.code}>Elegir {plan.name}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg></a>
						</article>
					))}
				</div>
				<p class="plan-note">Primero probá tus 3 imágenes gratis. Elegí un plan solo cuando quieras seguir.</p>
			</div>
		</section>

		<section class="faq-section">
			<div class="section-inner faq-grid">
				<div>
					<span class="section-kicker">PREGUNTAS FRECUENTES</span>
					<h2>Todo claro antes de empezar.</h2>
					<p>Si sabés elegir una foto, ya sabés usar Creattia.</p>
				</div>
				<div>{faqs.map((faq) => <details><summary><span>{faq.q}</span><b>+</b></summary><p>{faq.a}</p></details>)}</div>
			</div>
		</section>

		<section class="final-section">
			<div class="final-card section-inner">
				<div class="final-glow" aria-hidden="true"></div>
				<div class="final-moki"><img src="/images/creattia/moki-mascot.webp" alt="" width="1254" height="1254" loading="lazy" /></div>
				<div class="final-copy">
					<span class="section-kicker">PROBALO CON TU MARCA</span>
					<h2>Creá tu primera imagen ahora.</h2>
					<p>Probá el flujo completo con 3 generaciones gratis. Sin tarjeta.</p>
					<a href="/app/" class="button button-primary">Crear 3 imágenes gratis <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg></a>
					<small>Google o email · Todo queda guardado</small>
				</div>
			</div>
		</section>
	</main>

	<footer class="site-footer">
		<div class="section-inner footer-inner">
			<a href="#top" class="brand footer-brand"><img src="/images/creattia/moki-favicon-96.png" alt="" width="96" height="96" /><b>Creattia</b></a>
			<p>Imágenes con IA listas para vender.</p>
			<nav aria-label="Información legal"><a href="/legal/terminos/">Términos</a><a href="/legal/privacidad/">Privacidad</a></nav>
			<small>© {currentYear} Creattia</small>
		</div>
	</footer>

	<style>
		:global(html) { scroll-behavior: smooth; }
		:global(body) { margin: 0; background: #fff; color: #1d1921; font-family: Inter, system-ui, sans-serif; }
		:global(a) { -webkit-tap-highlight-color: transparent; }
		main { overflow: hidden; }
		.section-inner { width: min(1120px, calc(100% - 40px)); margin-inline: auto; }
		.section-kicker, .eyebrow { display: inline-flex; align-items: center; gap: 9px; color: #7543da; font-size: 10px; font-weight: 850; letter-spacing: .16em; }
		.eyebrow i { width: 7px; height: 7px; border-radius: 50%; background: #8654e7; box-shadow: 0 0 0 6px rgba(134, 84, 231, .1); }
		.button { display: inline-flex; align-items: center; justify-content: center; gap: 11px; color: #fff; text-decoration: none; font-weight: 800; }
		.button svg, .plans-grid svg { width: 17px; height: 17px; fill: none; stroke: currentColor; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
		.button-primary { min-height: 58px; padding: 0 29px; border-radius: 15px; background: linear-gradient(135deg, #8755ef, #5b27c7); box-shadow: 0 19px 42px rgba(100, 45, 213, .27), inset 0 1px rgba(255, 255, 255, .25); font-size: 14px; transition: transform .2s ease, box-shadow .2s ease; }
		.button-primary:hover { transform: translateY(-3px); box-shadow: 0 25px 55px rgba(100, 45, 213, .35), inset 0 1px rgba(255, 255, 255, .25); }

		.nav-shell { position: absolute; z-index: 100; inset: 0 0 auto; background: transparent; }
		.nav-inner { width: min(1180px, calc(100% - 40px)); height: 82px; margin: auto; display: flex; align-items: center; justify-content: space-between; gap: 24px; }
		.brand { display: inline-flex; align-items: center; gap: 10px; color: #211d24; text-decoration: none; }
		.brand img { width: 43px; height: 43px; object-fit: contain; filter: none; }
		.brand b { font-size: 17px; letter-spacing: -.025em; }
		.button-small { min-height: 46px; padding: 0 20px; border-radius: 13px; background: linear-gradient(135deg, #8250ea, #5c29c8); box-shadow: 0 13px 30px rgba(100, 49, 205, .2); font-size: 12px; transition: transform .2s ease, box-shadow .2s ease; }
		.button-small:hover { transform: translateY(-2px); box-shadow: 0 18px 36px rgba(100, 49, 205, .28); }

		.hero { position: relative; padding: 144px 0 92px; overflow: hidden; background: radial-gradient(circle at 76% 25%, rgba(173, 134, 255, .17), transparent 26%), linear-gradient(180deg, #fff, #faf7fd); }
		.hero-grid { position: absolute; inset: 0; opacity: .5; background-image: linear-gradient(rgba(111, 63, 205, .045) 1px, transparent 1px), linear-gradient(90deg, rgba(111, 63, 205, .045) 1px, transparent 1px); background-size: 40px 40px; mask-image: linear-gradient(#000, transparent 90%); }
		.hero-orb { position: absolute; border-radius: 50%; filter: blur(130px); pointer-events: none; }
		.hero-orb-one { width: 560px; height: 560px; left: -330px; top: -280px; background: #d2b8ff; opacity: .34; }
		.hero-orb-two { width: 390px; height: 390px; right: -160px; top: 500px; background: #e5c8ff; opacity: .25; }
		.hero-inner { position: relative; z-index: 2; width: min(1180px, calc(100% - 40px)); margin: auto; }
		.hero-copy { max-width: 1050px; margin: auto; text-align: center; }
		.hero-copy h1 { max-width: 1040px; margin: 28px auto 24px; font-size: clamp(58px, 6.5vw, 92px); line-height: .95; letter-spacing: -.067em; text-wrap: balance; }
		.hero-copy h1 em, .split-heading h2 em, .memory-copy h2 em, .business-heading h2 em, .light-heading h2 em { color: #7442dc; font-style: normal; }
		.hero-copy > p { max-width: 760px; margin: 0 auto; color: #68616b; font-size: 18px; line-height: 1.65; text-wrap: balance; }
		.hero-copy > p strong { color: #282329; }
		.hero-actions { display: flex; align-items: center; justify-content: center; gap: 20px; margin-top: 31px; }
		.hero-actions > span { color: #827a87; font-size: 12px; }
		.hero-actions > span b { color: #27a871; }
		.hero-showcase { position: relative; max-width: 1100px; margin: 60px auto 0; overflow: hidden; border: 1px solid rgba(116, 66, 220, .12); border-radius: 32px; background: rgba(255, 255, 255, .84); box-shadow: 0 38px 95px rgba(73, 43, 93, .14), 0 2px 0 rgba(255, 255, 255, .9) inset; backdrop-filter: blur(16px); }
		.showcase-video { position: relative; height: 710px; overflow: hidden; background: #f7f3fa; }
		.showcase-video video { width: 100%; height: 100%; display: block; object-fit: cover; object-position: center; }
		.hero-proof { max-width: 1020px; min-height: 83px; margin: 0 auto; padding: 0 34px; display: flex; align-items: center; justify-content: space-between; gap: 24px; border: 1px solid rgba(53, 40, 61, .09); border-top: 0; border-radius: 0 0 24px 24px; background: rgba(255, 255, 255, .7); }
		.hero-proof span { display: flex; flex-direction: column; gap: 5px; text-align: center; }
		.hero-proof strong { font-size: 13px; }
		.hero-proof small { color: #918996; font-size: 10px; }
		.hero-proof > i { width: 1px; height: 30px; background: rgba(52, 42, 60, .12); }

		.living-library { padding: 118px 0; background: linear-gradient(180deg, #fff, #f8f5fb); }
		.split-heading { display: grid; grid-template-columns: 1.12fr .65fr; gap: 80px; align-items: end; }
		.split-heading h2, .center-heading h2, .memory-copy h2, .faq-grid h2 { margin: 18px 0 0; font-size: clamp(42px, 4.7vw, 64px); line-height: 1.01; letter-spacing: -.058em; text-wrap: balance; }
		.split-heading > p { margin: 0; color: #6e6873; font-size: 15px; line-height: 1.75; }
		.category-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 58px; }
		.category-grid article { padding: 25px; border: 1px solid #e8e2eb; border-radius: 20px; background: #fff; box-shadow: 0 15px 42px rgba(38, 27, 50, .045); transition: transform .22s ease, box-shadow .22s ease; }
		.category-grid article:hover { transform: translateY(-5px); box-shadow: 0 25px 52px rgba(38, 27, 50, .1); }
		.category-grid header { display: flex; align-items: center; justify-content: space-between; }
		.category-grid header span { color: #aaa2ae; font-size: 9px; font-weight: 800; }
		.category-grid header i { width: 10px; height: 10px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 0 7px color-mix(in srgb, var(--accent) 12%, transparent); }
		.category-grid h3 { margin: 32px 0 9px; font-size: 21px; letter-spacing: -.04em; }
		.category-grid p { min-height: 42px; margin: 0 0 20px; color: #88818d; font-size: 11px; line-height: 1.55; }
		.category-grid article > div { display: flex; flex-wrap: wrap; gap: 7px; }
