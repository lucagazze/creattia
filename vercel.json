{
  "rewrites": [
    {
      "source": "/api/google-signin",
      "destination": "/api/complete-contact"
    },
    {
      "source": "/api/preview",
      "destination": "/api/oauth"
    },
    {
      "source": "/api/shopify-callback",
      "destination": "/api/oauth?action=shopify-callback"
    },
    {
      "source": "/api/tiendanube-callback",
      "destination": "/api/oauth?action=tiendanube-callback"
    },
    {
      "source": "/api/mercadolibre-callback",
      "destination": "/api/oauth?action=mercadolibre-callback"
    },
    {
      "source": "/api/tiktok-callback",
      "destination": "/api/oauth?action=tiktok-callback"
    },
    {
      "source": "/api/tiktok-content-callback",
      "destination": "/api/oauth?action=tiktok-content-callback"
    },
    {
      "source": "/api/webhook/store-redact",
      "destination": "/api/oauth?action=tiendanube-webhook&topic=store-redact"
    },
    {
      "source": "/api/webhook/customers-redact",
      "destination": "/api/oauth?action=tiendanube-webhook&topic=customers-redact"
    },
    {
      "source": "/api/webhook/customers-data",
      "destination": "/api/oauth?action=tiendanube-webhook&topic=customers-data"
    },
    {
      "source": "/api/shopify-webhook/customers-data",
      "destination": "/api/oauth?action=shopify-webhook&topic=customers-data"
    },
    {
      "source": "/api/shopify-webhook/customers-redact",
      "destination": "/api/oauth?action=shopify-webhook&topic=customers-redact"
    },
    {
      "source": "/api/shopify-webhook/shop-redact",
      "destination": "/api/oauth?action=shopify-webhook&topic=shop-redact"
    },
    {
      "source": "/api/klaviyo/:path*",
      "destination": "/api/klaviyo/[...path]"
    },
    {
      "source": "/api/shopify/:path*",
      "destination": "/api/shopify/[...path]"
    },
    {
      "source": "/((?!api/|.*\\.html$|.*\\.txt$|assets/|email-images/|email-library/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/tiktok-review.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/update-cerebro",
      "schedule": "0 9 * * *"
    }
  ]
}
