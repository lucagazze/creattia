	/* ==========================================
	   THE ALL-IN-ONE TOOL SECTION
	   ========================================== */
	.all-in-one-section {
		padding: 100px 20px;
		background: #FFF;
	}

	/* ==========================================
	   3D CYLINDER CAROUSEL (TryHolo Clone)
	   ========================================== */
	.cylinder-carousel-container {
		width: 100%;
		max-width: min(100vw - 1.5rem, 1920px);
		margin: 60px auto 0;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: visible;
		perspective: var(--carousel-perspective);
		height: var(--carousel-height);
		--carousel-card-w: 220px;
		--carousel-card-h: 390px;
		--carousel-radius: 420px;
		--carousel-perspective: 1240px;
		--carousel-height: 520px;
	}

	@media (max-width: 809px) {
		.cylinder-carousel-container {
			--carousel-card-w: 140px;
			--carousel-card-h: 250px;
			--carousel-radius: 280px;
			--carousel-perspective: 1000px;
			--carousel-height: 360px;
		}
	}

	.carousel-cylinder {
		position: relative;
		transform-style: preserve-3d;
		width: 0;
		height: 0;
		will-change: transform;
	}

	.cylinder-card {
		position: absolute;
		border-radius: 20px;
		overflow: hidden;
		box-shadow: 0 15px 40px rgba(0, 0, 0, 0.08);
		border: 1px solid var(--border-color);
		background: #ffffff;
		width: var(--carousel-card-w);
		height: var(--carousel-card-h);
		left: calc(var(--carousel-card-w) / -2);
		top: calc(var(--carousel-card-h) / -2);
		backface-visibility: visible;
		transition: transform 0.1s ease-out;
	}

	.cylinder-card img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(5px); }
		to { opacity: 1; transform: translateY(0); }
	}

	/* ==========================================
	   BRAND DNA SECTION
	   ========================================== */
	.brand-dna-section {
		padding: 100px 20px;
		max-width: 1200px;
		margin: 0 auto;
	}

	.dna-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 20px;
